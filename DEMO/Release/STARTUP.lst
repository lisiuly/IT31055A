  1255                              
  1256                              ;==========================================
  1257                              ; Public declare area
  1258                              ;==========================================
  1259                              .PUBLIC	L_PowerOn
  1260                              .PUBLIC User_Code_Start
  1261                              ;.PUBLIC		IOD_Attmap	
  1262                              ;.PUBLIC		IOD_Dirmap	
  1263                              ;.PUBLIC		IOD_Datmap
  1264                              ;==========================================
  1265                              ;Variable RAM declare area
  1266                              ;==========================================
  1267 00000080                     .PAGE0 ; PAGE指定列在一页上的最大列数和一行上最大的字符数
  1268 00000080 FF                  R_2Hz		ds	1
  1269 00000081 FF                  R_128Hz		ds	1
  1270 00000082 FF                  R_INTFlag	ds	1
  1271                              
  1272                              ;IOD_Attmap	ds	1
  1273                              ;IOD_Dirmap	ds	1
  1274                              ;IOD_Datmap	ds	1
  1275                              ;==========================================
  1276                              ; code starting 
  1277                              ;==========================================
  1278 0000E007                     .CODE
  1279 0000E007                     User_Code_Start:
  1280 0000E007                     Code_Start:
  1281 0000E007 78                  		SEI					; 置中断禁止位
  1282 0000E008 A2 FF               		LDX		#FFH		;
  1283 0000E00A 9A                  		TXS					;x-->栈指针
  1284                              
  1285 0000E00B A5 08               		LDA		P_WAKEUP_Ctrl	;唤醒源代码控制寄存器
  1286 0000E00D AA                  		TAX
  1287 0000E00E 29 03               		AND		#(D_WakeupKey+D_WakeupTMBA);+D_Wakeup128Hz) ;WakeupKey+TimeBaseA wake up(1/2hz)---------开启128Hz唤醒
  1288 0000E010 F0 30               		BEQ		L_PowerOn        ;No Wakeup     
  1289                              		
  1290 0000E012 A9 00                       LDA		#00
  1291 0000E014 85 08               		STA		P_WAKEUP_Ctrl    ;clear wakeup flag
  1292                              			
  1293 0000E016 A9 20               		LDA		#0x20
  1294 0000E018 85 18               		STA		P_CLK_CPU_Ctrl		; //after sleep mode wake up, sys=4M CPU=4M/1;			
  1295                              
  1296 0000E01A 8A                  		TXA
  1297 0000E01B 29 02               		AND		#D_WakeupTMBA  
  1298                              ;   	BNE		F_2HzWakeUp
  1299 0000E01D F0 03               		BEQ		F_keyWakeup    ;Judge Wakeup
  1300 0000E01F 4C 27 E0            		JMP		F_2HzWakeUp
  1301                              ;		TXA		
  1302                              ;		AND		#D_Wakeup128Hz
  1303                              ;		BNE		F_128HzWakeUp
  1304                              ;		
  1305                              
  1306 0000E022                     F_keyWakeup:
  1307                              ;       LDA		#D_TBL_Clr
  1308                              ;		STA		P_INT_Clear1   
  1309 0000E022 58                  		CLI
  1310 0000E023 EA                  		nop
  1311 0000E024 4C 3C E1            		JMP		L_ServiceLoop
  1312                              		
  1313 0000E027                     F_2HzWakeUp:                           ;半秒 0.5s	  
  1314 0000E027 A9 00                 		LDA		#00
  1315 0000E029 85 80                 		STA		R_2Hz
  1316 0000E02B A9 08                 		LDA		#D_TMBAInt
  1317 0000E02D 85 43               		STA		P_INT_TimeBaseA_Clear
  1318 0000E02F 20 50 E6              		JSR		F_2Hz_Cnt
  1319 0000E032 20 F5 E1            	    JSR		F_RealTimeClock   ;rtc		
  1320 0000E035 20 7D F2            	    JSR	    F_JudgeRFC		;温湿度检测	    	
  1321 0000E038 4C 3C E1            	    JMP		L_ServiceLoop	
  1322                              	    
  1323 0000E03B                     F_128HzWakeUp:
  1324 0000E03B A9 00               		LDA		#00
  1325 0000E03D 85 81               		STA		R_128Hz
  1326                              ;		JSR		F_128Hz_Cnt
  1327 0000E03F 4C 3C E1            		JMP		L_ServiceLoop
  1328                              		
  1329 0000E042                     L_PowerOn:  ;---------------------;POWER UP	开机		
  1330                              		%InitSystem
  1331 0000E042 A9 00             1 		LDA		#0
  1332 0000E044 85 0E             1 		STA		P_Reset_Status	;Clear AC key reset flag
  1333                            1 		%Enable32KLF
  1334                            2 
  1335 0000E046 A9 00             2 		LDA		#D_LFEnable
  1336 0000E048 85 0C             2 		STA		P_CLK_32768_En
  1337                            2 
  1338                              		
  1339                              		;CPU时钟选择
  1340 0000E04A A9 44               		LDA		#0x44					;0100 0100
  1341 0000E04C 85 18               		STA		P_CLK_CPU_Ctrl ;		; Set Fcpu = (500KHz) / 16
  1342 0000E04E EA                  		nop
  1343 0000E04F A9 24               		LDA		#0x24					;0010 0100
  1344 0000E051 85 18               		STA		P_CLK_CPU_Ctrl;			; Set Fcpu = (4MHz) / 16
  1345 0000E053 EA                  		nop
  1346 0000E054 A9 20               		LDA		#0x20					;0010 0000
  1347 0000E056 85 18               		STA		P_CLK_CPU_Ctrl		; //sys=4M cpu=4M/1;
  1348                              
  1349                              		%ClrSRAM
  1350                            1 
  1351                            1 		%FillSram	#0
  1352                            2 		
  1353 0000E058 A9 82             2 		LDA		#.LOW.(C_SramAddrStart+2)
  1354 0000E05A 85 80             2 		STA		C_SramAddrStart
  1355 0000E05C A9 00             2 		LDA		#.HIGH.(C_SramAddrStart+2)
  1356 0000E05E 85 81             2 		STA		C_SramAddrStart+1
  1357                            2 		
  1358 0000E060 A2 00             2 		LDX     #0
  1359 0000E062                   2 ?L_FillLoop000F1:
  1360 0000E062 A9 00             2         LDA     #0
  1361 0000E064 81 80             2 		STA     (C_SramAddrStart,X)
  1362                            2 		
  1363 0000E066 A5 81             2 		LDA     C_SramAddrStart+1
  1364 0000E068 C9 00             2 		CMP     #.HIGH.C_SramAddrEnd
  1365 0000E06A 90 06             2 		BCC     ?L_IncSramAddr000F1
  1366 0000E06C A5 80             2 		LDA     C_SramAddrStart
  1367 0000E06E C9 FF             2 		CMP     #.LOW.C_SramAddrEnd
  1368 0000E070 B0 0B             2 		BCS     ?L_End000F1
  1369                            2 		
  1370 0000E072                   2 ?L_IncSramAddr000F1:    ;Increase sram address
  1371 0000E072 E6 80             2         INC     C_SramAddrStart
  1372 0000E074 D0 EC             2 		BNE     ?L_FillLoop000F1
  1373 0000E076 E6 81             2 		INC     C_SramAddrStart+1
  1374                            2 		%WatchDogClear
  1375                            3 
  1376 0000E078 85 0F             3 	   STA	   P_WDT_Flag_Clear
