   387                      <       ;Macro Name: %M_ClearWatchDog
   388                      <       ;Purpose: Clear Watchdog
   389                      <       ;Destroy: A
   390                      <       ;;============================================================================
   391                      <       %M_ClearWatchDog:		.MACRO 
   392                      <       	LDA		#D_WDT_Clear
   393                      <       	STA		P_WDT_Flag_Clear			; Clear WDT
   394                      <       	.ENDM
   395                      <       ;;============================================================================
   396                      <       ;Macro Name: %M_DisAllInt
   397                      <       ;Purpose: Disable all interrupt 
   398                      <       ;Destroy: A
   399                      <       ;;============================================================================
   400                      <       %F_InitINT:		.MACRO
   401                      <       		LDA		#00000111b		;2HZ （bit0~2) for 111 is 4K 			;timeBaseA 2hz timeBaseB 16hz
   402                      <       		STA		P_TIMER_TimeBase_Sel		
   403                      <       		LDA		#D_128HzInt+D_TMBAInt+D_TMBBInt;+D_Timer0Int
   404                      <       		STA		P_INT_Ctrl
   405                      <       		LDA		#00
   406                      <       		STA		P_INT_Ctrl2		;disable TMR1 INT
   407                      <       ;		LDA		#D_TimerEn+D_TimerFallEdge+D_TimerSrcA_VDD+D_TimerSrcB_LF
   408                      <       ;		STA		P_TIMER_Timer0_Ctrl
   409                      <       ;		LDA		#0xC8
   410                      <       ;		LDA		#0xFC
   411                      <       ;		STA		P_TIMER_TM0Data_LB		;8k
   412                      <       ;		LDA		#0xFF
   413                      <       ;		STA		P_TIMER_TM0Data_HB
   414                      <       	.ENDM
   415                      <       ;;============================================================================
   416                      <       ;Macro Name: %DisableLCD
   417                      <       ;Purpose: Disable LCD
   418                      <       ;Destroy: A
   419                      <       ;;============================================================================
   420                      <       %DisableLCD:		.MACRO
   421                      <       	
   422                      <       		LDA		#(D_Duty_1_5+D_Bias_1_4)	;+D_ScanEnable)
   423                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   424                      <       		
   425                      <       		LDA     #D_VLCD_33         ;VLCD = 4.5V (max value)
   426                      <       		STA     P_LCD_VLCD_Ctrl
   427                      <       	.ENDM
   428                      <       ;-----------------------------------------------------------------------------
   429                      <       ; Macro Name:	%M_InitLCD
   430                      <       ; Description:	Initialize LCD configuration after power on
   431                      <       ;-----------------------------------------------------------------------------	
   432                      <       ;%M_InitLCD:		.MACRO
   433                      <       ;    LDA		#D_LCDMode_Normal+D_LCDSetting_3Bias_4Duty+D_LCDGreenMode_En
