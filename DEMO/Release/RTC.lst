    71                      <       ;Macro Name: %DisableLCD
    72                      <       ;Purpose: Disable LCD
    73                      <       ;Destroy: A
    74                      <       ;;============================================================================
    75                      <       %DisableLCD:		.MACRO
    76                      <       	
    77                      <       		LDA		#(D_Duty_1_5+D_Bias_1_4)	;+D_ScanEnable)
    78                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
    79                      <       		
    80                      <       		LDA     #D_VLCD_33         ;VLCD = 4.5V (max value)
    81                      <       		STA     P_LCD_VLCD_Ctrl
    82                      <       	.ENDM
