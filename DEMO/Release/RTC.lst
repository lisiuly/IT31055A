   531                      <       LCDConvert		.MACRO  com,seg
   532                      <       ;			DB	com*8+(seg/8)+00H,1<<(seg.AND.07H)
   533                      <       ;			DB	(com*8+07H)-(seg/8),1<<(seg.AND.07H)	;LB25B
   534                      <       ;			DB	com*4+(seg/8)+50H,1<<(seg.AND.07H)	;L11A\B
   535                      <       ;			DB	com*6+(seg/8)+20H,1<<(seg.AND.07H)	;L31B
   536                      <       ;LCDConvert:		.Macro	com,seg
   537                      <       ;			DB	com*4+(seg/8)+A0H,1<<(seg.AND.07H)	;GPL10A
   538                      <       			DB	com*10H+(seg/8)+00H,1<<(seg.AND.07H)	;GPL813P01;
   539                      <       			
   540                      <       			.ENDM
