   357                      <       %F_Initinal_IO	.MACRO
   358                      <       		LDA		#00000000b		
   359                      <       		STA		P_IO_PortA_Dir
   360                      <       		LDA		#00000000b		
   361                      <       		STA		P_IO_PortA_Data	
   362                      <       		
   363                      <       		LDA		#0
   364                      <       		STA		P_IO_PortB_Attrib
   365                      <       		LDA		#00000011b		
   366                      <       		STA		P_IO_PortB_Dir
   367                      <       		LDA		#00000000b		
   368                      <       		STA		P_IO_PortB_Data		;PB1·äĂůĆ÷Ł¬PB0±łąâ
   369                      <       
   370                      <       		LDA		#00H
   371                      <       		STA		P_IO_PortC_Dir
   372                      <       		LDA		#00000000b
   373                      <       		STA		P_IO_PortC_Data	
   374                      <       		
   375                      <       		LDA		#00h
   376                      <       		STA		P_IO_PortD_Attrib		
   377                      <       		LDA		#00000000b		
   378                      <       		STA		P_IO_PortD_Dir
   379                      <       		STA		P_IOD_DIR_Map	
   380                      <       		LDA		#00000000b
   381                      <       		STA		P_IO_PortD_Data		
   382                      <       		STA		R_PortD_Data_Buf
   383                      <       
   384                      <       		LDA		#00000000b			;PE0/PE1/PE2 Č«˛ż×÷ÎŞ°´ĽüĘäČë
   385                      <       		STA		P_IO_PortE_Dir
   386                      <       		LDA		#00000000b			
   387                      <       		STA		P_IO_PortE_Data		
   388                      <       		
   389                      <       		LDA		#00
   390                      <       		STA		P_IO_Ctrl			;all as normal IO
   391                      <       		.ENDM
