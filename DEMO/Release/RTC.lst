     8                      <       C_DPRAMAddrEnd   		.EQU		3FFFH	;DPRAM end address
     9                      <       
    10                      <       D_Bit0					equ		01H
    11                      <       D_Bit1					equ		02H
    12                      <       D_Bit2					equ		04H
    13                      <       D_Bit3					equ		08H
    14                      <       D_Bit4					equ		10H
    15                      <       D_Bit5					equ		20H
    16                      <       D_Bit6					equ		40H
    17                      <       D_Bit7					equ		80H
    18                      <       
    19                      <       C_High		equ	0x01
    20                      <       C_Input		equ	0x00
    21                      <       
    22                      <       ;PCDir for 1  is output, for 0 is input
    23                      <       C_PC0Dir	equ	D_Bit0
    24                      <       C_PC1Dir	equ	D_Bit1
    25                      <       C_PC2Dir	equ	D_Bit2
    26                      <       C_PC3Dir	equ	D_Bit3
    27                      <       C_PC6Dir	equ	D_Bit6
    28                      <       C_PC7Dir	equ	D_Bit7
    29                      <       
    30                      <       D_BLight	equ	D_Bit2
    31                      <       D_Pulse		equ	D_Bit3
    32                      <       D_LVD		equ	D_Bit5
    33                      <       
