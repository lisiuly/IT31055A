   761                              ;YearMonthDate	        EQU	    1			 ;define year month date enable 		
   762                              	
   763                              ;------------------------------------------------------------------------------
   764 00000083                     .PAGE0
   765                              ;
   766 00000083 FF FF FF            RTC		             .DS	 3
   767                              	; RTC+0 --> Hour (BCD)
   768                              	; RTC+1 --> Minute (BCD)
   769                              	; RTC+2 --> Second (BCD)
   770                              	;  -------------------------------------------
   771                              	; |             | RTC+0   | RTC+1   | RTC+2   |
   772                              	; |-------------|---------|---------|---------|
   773                              	; | Description | Hour    | Minute  | Second  |
   774                              	; |	            | 00 - 23 | 00 - 59 | 00 - 59 |        
   775                              	; |		        | (BCD)   | (BCD)   | (BCD)   |         |
   776                              	;  -------------------------------------------
   777                              ;
   778 00000086 FF FF FF            DATE	            .DS	    3
   779                              	; DATE+0 --> 00-99(BCD) Year
   780                              	; DATE+1 --> .7 = 1 --> 20xx (Year)
   781                              	;		        = 0 --> 19xx (Year)
   782                              	;	         .6 - .4 --> 00H - 06H --> SUN - SAT (Week)
   783                              	;	         .3 - .0 --> 00H - 0BH --> JAN - DEC (Month)
   784                              	; DATE+2 --> 01 - 31(BCD) Date
   785                              ;
   786 00000089 FF                  R_TimeStatus	    .DS	    1       ;(.7 reserved!!!)
   787                              HalfSecToggle			EQU		01000000B
   788                              AddSecondOnly			EQU		00100000B
   789                              AddOthers				EQU		00010000B
   790 0000008A FF                  TR00				.DS	    1
   791 0000008B FF                  TR01				.DS		1
   792 0000008C FF                  TR02		    	.DS		1
   793 0000008D FF                  TR03				.DS		1
   794                              ;------------------------------------------------------------------------------
   795 0000E1F5                     .CODE
   796                              ;==============================================================================
   797 0000E1F5                     F_RealTimeClock:	;Level 1
   798 0000E1F5 A9 40               	LDA	#HalfSecToggle
   799 0000E1F7 45 89               	EOR	R_TimeStatus
   800 0000E1F9 85 89               	STA	R_TimeStatus
   801 0000E1FB 29 40               	AND	#HalfSecToggle
   802 0000E1FD D0 2C               	BNE	L_Time99	; 0.5 second only!!!
   803                              ;	1 second!!!
   804 0000E1FF 20 CE E3            	JSR	INC_SEC	;Level 2  
   805 0000E202 90 21               	BCC	L_OnlySEcAdd
   806                              
   807 0000E204 20 D3 E3            	JSR	INC_MIN	;Level 2
   808 0000E207 90 18               	BCC	L_OnlyMinAdd
   809                              	
   810                              	
   811 0000E209 20 E0 E3            	JSR	INC_HR	;Level 2
   812                              	
   813                              ;	IFDEF	YearMonthDate
   814 0000E20C 90 13               	BCC	L_OnlyHourAdd
   815 0000E20E 20 B9 E3            	JSR	INC_DAT	;Level 3
   816 0000E211 90 08               	BCC	L_Time01
   817 0000E213 20 87 E3            	JSR	INC_MON	;Level 2
   818 0000E216 90 03               	BCC	L_Time01
   819 0000E218 20 C5 E3            	JSR	INC_YER	;Level 2
   820 0000E21B                     L_Time01:
   821 0000E21B 20 55 E2            	JSR	WEEKCAL	;Level 3
   822 0000E21E 20 1F E3            	JSR	MAXDCMP	;Level 3
   823                              ;	ELSE
   824                              ;	ENDIF
   825 0000E221                     L_OnlyHourAdd:
   826 0000E221                     L_OnlyMinAdd:	
   827 0000E221 A9 10               	LDA	#AddOthers
   828 0000E223 D0 02               	BNE	L_AddAll	;@JMP
   829 0000E225                     L_OnlySEcAdd:
   830 0000E225 A9 20               	LDA	#AddSecondOnly
   831 0000E227                     L_AddAll:
   832 0000E227 05 89               	ORA	R_TimeStatus
   833 0000E229 85 89               	STA	R_TimeStatus
   834 0000E22B                     L_Time99:
   835 0000E22B 60                  	RTS
   836                              ;
   837                              ;------------------------------------------------------------------------------
   838                              ;
   839 0000E22C                     F_ClearIncStatus:
   840 0000E22C A9 CF               	LDA	#(.NOT.(AddSecondOnly+AddOthers))
   841 0000E22E 25 89               	AND	R_TimeStatus
   842 0000E230 85 89               	STA	R_TimeStatus
   843 0000E232 60                  	RTS
   844                              ;
   845                              ;------------------------------------------------------------------------------
   846                              ;
   847 0000E233                     F_ResetRealTimeClock:          ;żŞ»úĎÔĘľłőÖµ(Ä¬ČĎÖµ)
   848 0000E233 A9 00               	LDA	#00H
   849 0000E235 85 83               	STA	RTC+0
   850 0000E237 A9 00               	LDA	#00H
   851 0000E239 85 84               	STA	RTC+1
   852 0000E23B A9 00               	LDA	#00H		;test use
   853 0000E23D 85 85               	STA	RTC+2	
   854 0000E23F A9 10               	LDA	#AddOthers
   855 0000E241 85 89               	STA	R_TimeStatus
   856                              ;	IFDEF	YearMonthDate
   857                              	; DATE+0 --> 00-99 (Year)
   858                              	; DATE+1 --> .7 = 1 --> 20xx (Year)
   859                              	;		= 0 --> 19xx (Year)
   860                              	;	     .6 - .4 --> 00H - 06H --> SUM - SAT (Week)
   861                              	;	     .3 - .0 --> 00H - 0BH --> JAN - DEC (Month)
   862                              	; DATE+2 --> 01 - 31 (Date)
   863 0000E243 A9 25               	LDA	#00100101B			; 2025-1-1 	;2(0010)4(0100)  (BCD8421)
   864 0000E245 85 86               	STA	DATE+0
   865 0000E247 A9 B0               	LDA	#10110000B			;1(20xx) 001(Mon) 0000(JAN)
   866 0000E249 85 87               	STA	DATE+1
   867                              ;	STA	R_LaZhuMonth
   868 0000E24B A9 01               	LDA	#00000001B
   869 0000E24D 85 88               	STA	DATE+2				;DATE+2 --> 01 - 31 (Date)
   870                              ;	ELSE
   871                              ;	ENDIF
   872 0000E24F 60                  	RTS
   873                              ;
   874                              ;------------------------------------------------------------------------------
   875 0000E250                     F_ClearSecond:
   876 0000E250 A9 00               	LDA	#00
   877 0000E252 85 85               	STA	RTC+2
   878 0000E254 60                  	RTS
   879                              ;	IFDEF	YearMonthDate
   880                              ;------------------------------------------------------------------------------
   881                              ; --- Week Calculate for Month ---
   882                              ; *** Use TR00 ***
   883                              ;	  TR01
   884                              ;	  TR02 Temp Week
   885                              ;         TR03
   886                              ;
   887 0000E255                     WEEKCAL:
   888 0000E255 A5 87               	LDA	DATE+1		;;
   889 0000E257 30 0D               	BMI	WEC_00		;;
   890 0000E259 A9 00               	LDA	#0
   891 0000E25B 85 8C               	STA	TR02		; 1/1/1900 as Sun
   892 0000E25D A5 86               	LDA	DATE
   893 0000E25F D0 09               	BNE	WEC_02
   894 0000E261 A9 01               	LDA	#1		; 1/1/1900 Mon
   895 0000E263 4C 68 E2            	JMP	WEC_01
   896 0000E266                     WEC_00:
   897 0000E266 A9 06               	LDA	#6		; 1/1/2000 Sat
   898 0000E268                     WEC_01:
   899 0000E268 85 8C               	STA	TR02
   900 0000E26A                     WEC_02:
   901 0000E26A A5 86               	LDA	DATE		; XXL_WeekX
   902 0000E26C 20 35 E4            	JSR	AROR
   903 0000E26F 85 8A               	STA	TR00
   904 0000E271                     WEC_03:
   905 0000E271 C6 8A               	DEC	TR00
   906 0000E273 30 15               	BMI	WEC_04
   907 0000E275 A5 8A               	LDA	TR00
   908 0000E277 29 01               	AND	#00000001B
   909 0000E279 D0 05               	BNE	L_Week01
   910 0000E27B A9 06               	LDA	#06H
   911 0000E27D 4C 82 E2            	JMP	L_Week02
   912 0000E280                     L_Week01:
   913 0000E280 A9 05               	LDA	#05H
   914 0000E282                     L_Week02:
   915 0000E282 85 8B               	STA	TR01
   916 0000E284 20 0D E3            	JSR	WADDUP
   917 0000E287 4C 71 E2            	JMP	WEC_03
   918                              ;
   919 0000E28A                     WEC_04:
   920 0000E28A A5 86               	LDA	DATE		; XXX?
   921 0000E28C 29 0F               	AND	#00001111B
   922 0000E28E 85 8A               	STA	TR00
   923 0000E290                     WEC_05:
   924 0000E290 C6 8A               	DEC	TR00
   925 0000E292 30 27               	BMI	WEC_06
   926 0000E294 A5 86               	LDA	DATE
   927 0000E296 29 10               	AND	#00010000B
   928 0000E298 D0 05               	BNE	L_Week001
   929 0000E29A A9 00               	LDA	#00
   930 0000E29C 4C A1 E2            	JMP	L_Week002
   931 0000E29F                     L_Week001:
   932 0000E29F A9 02               	LDA	#02
   933 0000E2A1                     L_Week002:
   934 0000E2A1 85 8D               	STA	TR03
   935 0000E2A3 A5 8A               	LDA	TR00
   936 0000E2A5 29 03               	AND	#00000011B
   937 0000E2A7 38                  	SEC
   938 0000E2A8 E5 8D               	SBC	TR03
   939 0000E2AA F0 05               	BEQ	L_Week003
   940 0000E2AC A9 01               	LDA	#1
   941 0000E2AE 4C B3 E2            	JMP	L_Week004
   942 0000E2B1                     L_Week003:
   943 0000E2B1 A9 02               	LDA	#2
   944 0000E2B3                     L_Week004:
   945 0000E2B3 85 8B               	STA	TR01
   946 0000E2B5 20 0D E3            	JSR	WADDUP
   947 0000E2B8 4C 90 E2            	JMP	WEC_05
   948                              ;
   949 0000E2BB                     WEC_06: 			; ?/XX
   950 0000E2BB A5 87               	LDA	DATE+1
   951 0000E2BD 29 0F               	AND	#00001111B
   952 0000E2BF 85 8A               	STA	TR00
   953                              ;
   954 0000E2C1                     WEC_07:
   955 0000E2C1 C6 8A               	DEC	TR00
   956 0000E2C3 30 1A               	BMI	WEC_08
   957 0000E2C5 A5 8A               	LDA	TR00
