  3296                              ;; F_CAL_HEX_BCD2 的结果在 OUT_M/OUT_L，这里先搬到通用显示缓冲，
  3297                              ;; 后面摄氏和华氏都复用同一套拆位显示逻辑。
  3298                              ;Disp_ProductRenderCurrentTempFromOut:
  3299                              ;			LDA		OUT_M
  3300                              ;			STA		R_TempBuf+5
  3301                              ;			LDA		OUT_L
  3302                              ;			STA		R_TempBuf+4
  3303                              ;			JMP		Disp_ProductRenderCurrentTempFromBuf
  3304                              
  3305                              ; R_TempBuf+5 是高两位 BCD，R_TempBuf+4 是低两位 BCD。
  3306                              ; F_DisplayHLValue 会把低 4 bit 放到 R_TempBuf，并把高 4 bit 留在 A。
  3307                              ; 这里先处理最高位：
  3308                              ; 1. 若十位非 0，就直接显示十位。
  3309                              ; 2. 若十位为 0 且百位非 0，就显示 0。
  3310                              ; 3. 若十位和百位都为 0，就最高位留空。
  3311                              ; 首次 PHA 只是为了让下面所有分支在 Disp_ProductCurTempH_Out 的 PLA 数量保持一致，
  3312                              ; 否则走“最高位留空”的分支时会把返回地址从栈里误弹出来，表现成跑飞或复位。
  3313 0000EB99                     Disp_ProductRenderCurrentTempFromBuf:
  3314 0000EB99 A5 A7               			LDA		R_TempBuf+5
  3315 0000EB9B 20 50 E7            			JSR		F_DisplayHLValue
  3316 0000EB9E A5 A2               			LDA		R_TempBuf
  3317 0000EBA0 D0 02               			BNE		Disp_ProductCurTempH_Out			
  3318 0000EBA2                     Disp_ProductCurTempH_Blank:
  3319 0000EBA2 A9 0A               			LDA		#0AH
  3320 0000EBA4                     Disp_ProductCurTempH_Out:
  3321 0000EBA4 A2 00               			LDX		#T_CurTeH
  3322 0000EBA6 20 C9 E6            			JSR		F_LcdDisplayDigital	
  3323 0000EBA9 A5 A8               			LDA		R_TempBuf+6
  3324 0000EBAB 20 50 E7            			JSR		F_DisplayHLValue
  3325 0000EBAE A2 0E               			LDX		#T_CurTeM
  3326 0000EBB0 20 C9 E6            			JSR		F_LcdDisplayDigital			
  3327 0000EBB3 A5 A2               			LDA		R_TempBuf
  3328 0000EBB5 A2 1C               			LDX		#T_CurTeL
  3329 0000EBB7 4C C9 E6            			JMP		F_LcdDisplayDigital
  3330                              
