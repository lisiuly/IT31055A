  1316                      <       
  1317                      <       ;===============================================================
  1318 0000E720             <       Display_OneBit:
  1319                      <       ;			%btsf	R_Flag1,D_LCD1Option,LCD2_DisplayOneBit
  1320 0000E720 BD 40 E8    <       	        LDA     T_Icon+1,X
  1321 0000E723 8D A5 00    <       	        STA     R_LcdSegmentPosition         ;data
  1322 0000E726 BD 3F E8    <       			LDA     T_Icon,X	
  1323 0000E729 AA          <       	        TAX
  1324 0000E72A BD 00 3E    <       	        LDA     3E00H,X
  1325 0000E72D 0D A5 00    <       	        ORA     R_LcdSegmentPosition 
  1326 0000E730 9D 00 3E    <       	        STA     3E00H,X
  1327 0000E733 60          <       	        RTS
  1328                      <       ;	  LCD2_DisplayOneBit:
  1329                      <       ;	  		LDA     T_Icon1+1,X
  1330                      <       ;	        STA     R_LcdSegmentPosition         ;data
  1331                      <       ;			LDA     T_Icon1,X	
  1332                      <       ;	        TAX
  1333                      <       ;	        LDA     00H,X
  1334                      <       ;	        ORA     R_LcdSegmentPosition 
  1335                      <       ;	        STA     00H,X
  1336                      <       ;	        RTS
