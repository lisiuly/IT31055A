  1348                      <       ;;****************************************************************************
  1349                      <       
  1350 0000E734             <       NoDisplay_OneBit:
  1351                      <       ;			%btsf	R_Flag1,D_LCD1Option,LCD2_NoDisplayOneBit
  1352 0000E734 BD 40 E8    <       	        LDA     T_Icon+1,X
  1353 0000E737 8D A5 00    <       	        STA     R_LcdSegmentPosition         ;data
  1354 0000E73A BD 3F E8    <       			LDA     T_Icon,X	
  1355 0000E73D AA          <       	        TAX
  1356 0000E73E AD A5 00    <       	        LDA     R_LcdSegmentPosition 
  1357 0000E741 49 FF       <       	        EOR     #FFH
  1358 0000E743 8D A5 00    <       	        STA     R_LcdSegmentPosition 
  1359 0000E746 BD 00 3E    <       			LDA     3E00H,X
  1360 0000E749 2D A5 00    <       	        AND     R_LcdSegmentPosition 
  1361 0000E74C 9D 00 3E    <       	        STA     3E00H,X
  1362 0000E74F 60          <       	        RTS
  1363                      <       ;	 LCD2_NoDisplayOneBit:
  1364                      <       ;	 		LDA     T_Icon1+1,X
  1365                      <       ;	        STA     R_LcdSegmentPosition         ;data
  1366                      <       ;			LDA     T_Icon1,X	
  1367                      <       ;	        TAX
  1368                      <       ;	        LDA     R_LcdSegmentPosition 
  1369                      <       ;	        EOR     #FFH
  1370                      <       ;	        STA     R_LcdSegmentPosition 
  1371                      <       ;			LDA     00H,X
  1372                      <       ;	        AND     R_LcdSegmentPosition 
  1373                      <       ;	        STA     00H,X
  1374                      <       ;	        RTS
