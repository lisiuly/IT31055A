  2823                              ;==============================================================================
  2824                              ; 产品显示框架
  2825                              ; 标准页和历史页共用同一套主布局，只切换页签和记录数据来源。
  2826                              ;==============================================================================
  2827                              ; 入口结构改成旧 RFC 的写法：最外层先按页面分发，再由各页面自己决定
  2828                              ; 是全刷、闪烁当前编辑位，还是直接返回。
  2829 0000E8D1                     F_Display:
  2830 0000E8D1                     F_DisplayProductUI:
  2831 0000E8D1 A5 9F               			LDA		R_ProductPage
  2832 0000E8D3 C9 04               			CMP		#D_PageMoldSet
  2833 0000E8D5 D0 03               			BNE		Disp_ProductPage
  2834 0000E8D7 4C 64 E9            			JMP		Disp_ProductMoldPage
  2835                              
  2836 0000E8DA                     Disp_ProductCheckHistory:
  2837 0000E8DA                     Disp_ProductStandardJump:
  2838 0000E8DA                     Disp_ProductStandardPage:
  2839 0000E8DA                     Disp_ProductHistoryPage:
  2840 0000E8DA                     Disp_ProductPage:
  2841                              			; 标准页和历史页共用一个入口，是否显示历史页签由 R_ProductPage 决定。
  2842                              			%btst	R_TimeStatus,AddOthers,Disp_ProductUpdateAll
  2843 0000E8DA AD 89 00          1           lda     R_TimeStatus               ;ex.   
  2844 0000E8DD 29 10             1           and     #AddOthers              ;  %btst 10H,_BIT0,N
  2845 0000E8DF D0 01             1           bne     Disp_ProductUpdateAll               ;  if(10H.0=1) goto N 
  2846 0000E8E1 60                  			RTS
  2847                              
  2848 0000E8E2                     Disp_ProductStandardUpdateAll:
  2849 0000E8E2                     Disp_ProductHistoryUpdateAll:
  2850 0000E8E2                     Disp_ProductUpdateAll:
  2851                              			; 标准页/历史页共用一套整页刷新，最后再按页面模式选择页签。
  2852 0000E8E2 20 EE E8            			JSR		Disp_ProductRefreshPagedBody
  2853 0000E8E5 A5 9F               			LDA		R_ProductPage
  2854 0000E8E7 C9 02               			CMP		#D_PageHistory
  2855 0000E8E9 F0 0A               			BEQ		Disp_ProductShowHistoryTab
  2856 0000E8EB 4C FF E8            			JMP		Disp_ProductShowTodayTab
  2857                              
  2858 0000E8EE                     Disp_ProductRefreshPagedBody:
  2859                              			; 公共整页刷新：清增量标志，并刷新标准/历史页共用主体。
  2860 0000E8EE 20 2C E2            			JSR		F_ClearIncStatus
  2861 0000E8F1 20 2C E9            			JSR		Disp_ProductRefreshCommonBody
  2862 0000E8F4 60                  			RTS
  2863                              
  2864 0000E8F5                     Disp_ProductShowHistoryTab:
  2865 0000E8F5 A5 A0               			LDA		R_HistoryPage
  2866 0000E8F7 C9 02               			CMP		#D_His48Hr
  2867 0000E8F9 F0 13               			BEQ		Disp_Product48Hr
  2868 0000E8FB C9 04               			CMP		#D_HisAllTm
  2869 0000E8FD F0 1E               			BEQ		Disp_ProductAllTm
  2870                              
  2871 0000E8FF                     Disp_ProductShowTodayTab:
  2872 0000E8FF A2 20               			LDX		#T_48Hr
  2873 0000E901 20 34 E7            			JSR		NoDisplay_OneBit
  2874 0000E904 A2 22               			LDX		#T_AllTm
  2875 0000E906 20 34 E7            			JSR		NoDisplay_OneBit
  2876 0000E909 A2 1E               			LDX		#T_Today
  2877 0000E90B 4C 20 E7            			JMP		Display_OneBit
  2878                              
  2879 0000E90E                     Disp_Product48Hr:
  2880 0000E90E A2 1E               			LDX		#T_Today
  2881 0000E910 20 34 E7            			JSR		NoDisplay_OneBit
  2882 0000E913 A2 22               			LDX		#T_AllTm
  2883 0000E915 20 34 E7            			JSR		NoDisplay_OneBit
  2884 0000E918 A2 20               			LDX		#T_48Hr
  2885 0000E91A 4C 20 E7            			JMP		Display_OneBit
  2886                              
  2887 0000E91D                     Disp_ProductAllTm:
  2888 0000E91D A2 1E               			LDX		#T_Today
  2889 0000E91F 20 34 E7            			JSR		NoDisplay_OneBit
  2890 0000E922 A2 20               			LDX		#T_48Hr
  2891 0000E924 20 34 E7            			JSR		NoDisplay_OneBit
  2892 0000E927 A2 22               			LDX		#T_AllTm
  2893 0000E929 4C 20 E7            			JMP		Display_OneBit
  2894                              
  2895                              
  2896                              ;Disp_ProductPrepareNormalPage:
  2897                              ;			; T_Other 不是设置页专用图标，而是共享的固定辅助位，普通页也要保持点亮。
  2898                              ;			LDX		#T_Other
  2899                              ;			JMP		Display_OneBit
  2900                              
  2901                              
  2902 0000E92C                     Disp_ProductRefreshCommonBody:
  2903                              			; 公共主体刷新：
  2904                              			; 1. 先准备当前页面对应的历史兼容缓冲。
  2905                              			; 2. 再依次写当前值、历史值、舒适度、趋势、Mold 和电池图标。
  2906                              			; 这些函数各自落在不同的 LCD 位区，不是重复写同一块区域。
  2907                              			; 当前真正的浪费点是 AddOthers 只有一个粗粒度脏标志，
  2908                              			; 只要任何一个区域变化，就会把整套主体刷新链都走一遍。
  2909                              ;			JSR		Disp_ProductPrepareNormalPage
  2910 0000E92C A2 00               			LDX		#T_Other
  2911 0000E92E 20 20 E7            			JSR		Display_OneBit			
  2912 0000E931 20 D0 F7            			JSR		F_LoadHistoryViewBuffers
  2913 0000E934 20 3A E9            			JSR		Disp_ProductRefreshValueArea
  2914 0000E937 4C 46 E9            			JMP		Disp_ProductRefreshStatusIcons
  2915                              
  2916                              
  2917 0000E93A                     Disp_ProductRefreshValueArea:
  2918                              			; 数值区：当前温湿度 + 历史 MAX/MIN。
  2919                              			; 这部分属于同一类“数码位刷新”，目前在 AddOthers 下整体更新。
  2920 0000E93A 20 C3 EA            			JSR		Disp_ProductCurrentTemp
  2921 0000E93D 20 F6 EB            			JSR		Disp_ProductTempRecords
  2922 0000E940 20 BA EB            			JSR		Disp_ProductCurrentHum
  2923 0000E943 4C 54 ED            			JMP		Disp_ProductHumRecords
  2924                              
  2925                              
  2926 0000E946                     Disp_ProductRefreshStatusIcons:
  2927                              			; 状态图标区：舒适度、趋势、Mold、电池。
  2928                              			; 当前已经改成按目标状态直接更新，互斥组只清其它位，
  2929                              			; 这样能避免目标图标在整页刷新时先灭再亮。
  2930                              			; 如果后面还要继续省刷新，再考虑给这些状态组补“上次状态缓存”。
  2931 0000E946 20 A1 E9            			JSR		Disp_ProductShowComfortState
  2932 0000E949 20 D9 E9            			JSR		Disp_ProductShowTempTrend
  2933 0000E94C 20 37 EA            			JSR		Disp_ProductShowHumTrend
  2934 0000E94F 20 95 EA            			JSR		Disp_ProductShowMoldAlert
  2935 0000E952 4C AB EA            			JMP		Disp_ProductShowBatteryIcon
  2936                              
  2937                              
  2938 0000E955                     Disp_ProductHidePageTabs:
  2939                              			; 这个 helper 现在只留给需要“整组页签全灭”的路径，例如 Mold 设置页。
