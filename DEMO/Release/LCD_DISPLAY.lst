  2779                              ;===================================================================
  2780                              ; Shared record initialization helper, still used by KEY.asm.
  2781                              ;===================================================================
  2782                              .PUBLIC			F_Start_RFCMM_Value
  2783 0000E877                     F_Start_RFCMM_Value:
  2784                              	%bitr	R_TempFlag1,(D_MaxTemp+D_MinTemp)
  2785 0000E877 AD D5 01          1           lda     R_TempFlag1               ;ex.  
  2786 0000E87A 29 FC             1           and     #.NOT.(D_MaxTemp+D_MinTemp)         ;  %bitr 10H,_BIT0;  10H.0=0
  2787 0000E87C 8D D5 01          1           sta     R_TempFlag1
  2788 0000E87F A9 00               	LDA		#00H
  2789 0000E881 8D B6 01            	STA		R_HistoryClearTm
  2790 0000E884 AD CC 01            	LDA		R_DispTemper+0
  2791 0000E887 8D D0 01            	STA		R_TempMin+0
  2792 0000E88A 8D CE 01            	STA		R_TempMax+0
  2793 0000E88D AD CD 01            	LDA		R_DispTemper+1
  2794 0000E890 8D D1 01            	STA		R_TempMin+1
  2795 0000E893 8D CF 01            	STA		R_TempMax+1
  2796 0000E896 AD C6 01            	LDA		R_DispTemper_F
  2797 0000E899 8D CA 01            	STA		R_MINDispTemper_F
  2798 0000E89C 8D C8 01            	STA		R_MAXDispTemper_F
  2799                              
  2800 0000E89F AD C7 01            	LDA		R_DispTemper_F+1
  2801 0000E8A2 8D CB 01            	STA		R_MINDispTemper_F+1
  2802 0000E8A5 8D C9 01            	STA		R_MAXDispTemper_F+1
  2803                              
  2804 0000E8A8 AD D2 01            	LDA		R_DispHum
  2805 0000E8AB 8D D3 01            	STA		R_HumMax
  2806 0000E8AE 8D D4 01            	STA		R_HumMin
  2807                              
  2808 0000E8B1 AD C1 01            	LDA		R_SpecFlag
  2809 0000E8B4 8D C3 01            	STA		R_TempMax_Sign
  2810 0000E8B7 8D C2 01            	STA		R_TempMin_Sign
  2811                              
  2812 0000E8BA AD A9 00            	LDA		R_TempFlag
  2813 0000E8BD 29 04               	AND		#D_TempFReg
  2814 0000E8BF 0D C3 01            	ORA		R_TempMax_Sign
  2815 0000E8C2 8D C3 01            	STA		R_TempMax_Sign
  2816                              
  2817 0000E8C5 AD A9 00            	LDA		R_TempFlag
  2818 0000E8C8 29 04               	AND		#D_TempFReg
  2819 0000E8CA 0D C2 01            	ORA		R_TempMin_Sign
  2820 0000E8CD 8D C2 01            	STA		R_TempMin_Sign
  2821 0000E8D0 60                  	RTS
