   598                      <       ; Macro Name:	%InitLCD
   599                      <       ; Description:	Initialize LCD configuration after power on
   600                      <       ;-----------------------------------------------------------------------------	
   601                      <       %InitLCD:		.MACRO
   602                      <       
   603                      <       		LDA		#(D_Duty_1_5+D_Bias_1_3+D_ScanEnable)
   604                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
