   524 0000F13F 20 E2 F0            		JSR		B_SCLSDA_0
   525 0000F142 20 15 F1            		JSR		F_I2C_Delay
   526 0000F145 20 D1 F0            		JSR		B_SCL_1
   527 0000F148 20 15 F1            		JSR		F_I2C_Delay
   528 0000F14B 20 AF F0            		JSR		B_SDA_1
   529 0000F14E 20 15 F1            		JSR		F_I2C_Delay	
