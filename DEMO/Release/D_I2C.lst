   676 0000F207 20 D1 F0            		JSR		B_SCL_1
   677 0000F20A 20 15 F1            		JSR		F_I2C_Delay
   678 0000F20D 20 C0 F0            		JSR		B_SCL_0
   679 0000F210 20 15 F1            		JSR		F_I2C_Delay
   680 0000F213 60                  			RTS	
