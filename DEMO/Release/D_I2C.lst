   581                              .PUBLIC	F_IIC_get8bit			
   582                              ;****************************************			
   583 0000F17E                     F_IIC_get8bit:	; Y = output 8bit data value
   584                              		;扢离SDA諳峈Input floating袨怓
   585 0000F17E 20 04 F1            		JSR		B_SDA_F
   586                              		;X桶尨bit腔跺杅,Y桶尨黍堤腔硉
   587 0000F181 A2 08               		LDX		#8
   588 0000F183 A0 00               		LDY		#0
   589 0000F185                     	?loop:
   590                              		; SCK = 1 and Delay		
   591 0000F185 20 D1 F0            		JSR		B_SCL_1
   592 0000F188 20 15 F1            		JSR		F_I2C_Delay
   593 0000F18B 20 15 F1            		JSR		F_I2C_Delay
   594                              		; Get SDA and Save to Y
   595 0000F18E A5 13               		LDA		P_I2C_Dat
   596 0000F190 29 10               		AND		#I2C_SDA
   597 0000F192 C9 10               		CMP		#I2C_SDA
   598 0000F194 98                  		TYA
   599 0000F195 2A                  		ROL		A			;植詢善腴諉彶
   600                              	;	ROR		A			;植腴善詢諉彶
   601 0000F196 A8                  		TAY
   602                              		;SCK = 0 and Delay
   603 0000F197 20 C0 F0            		JSR		B_SCL_0
   604 0000F19A 20 15 F1            		JSR		F_I2C_Delay	
   605 0000F19D 20 15 F1            		JSR		F_I2C_Delay
   606                              		; Check finish of 8 bit move out or not
   607 0000F1A0 CA                  		DEX
   608 0000F1A1 D0 E2               		BNE		?loop
   609                              		;扢离SDA output	low, 諉狟懂岆SACK麼SNACK,
   610 0000F1A3 20 9E F0            		JSR		B_SDA_0		
   611 0000F1A6 60                  			RTS	
