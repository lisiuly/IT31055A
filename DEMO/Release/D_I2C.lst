   514 0000F12F 20 15 F1            		JSR		F_I2C_Delay
   515 0000F132 20 15 F1            		JSR		F_I2C_Delay
   516 0000F135 20 9E F0            		JSR		B_SDA_0
   517 0000F138 20 15 F1            		JSR		F_I2C_Delay
   518 0000F13B 20 15 F1            		JSR		F_I2C_Delay	
