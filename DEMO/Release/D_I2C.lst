   398                              ;==========================================
   399                              ; code starting 
   400                              ;==========================================
   401 0000F09E                     .CODE
   402                              ;-------------SetIO Pin------------------------
   403                              ;***************************************
   404 0000F09E                     B_SDA_0:	;Set SDA output L
   405 0000F09E A5 C2               		LDA		P_IOD_DIR_Map
   406 0000F0A0 09 10               		ORA		#I2C_SDA
   407 0000F0A2 85 C2               		STA		P_IOD_DIR_Map
   408 0000F0A4 85 11               		STA		P_IO_PortD_Dir
   409 0000F0A6 A5 C4               		LDA		R_PortD_Data_Buf
   410 0000F0A8 29 EF               		AND		#.not.I2C_SDA
   411 0000F0AA 85 C4               		STA		R_PortD_Data_Buf
   412 0000F0AC 85 13               		STA		P_IO_PortD_Data
   413 0000F0AE 60                  			RTS			
   414                              ;***************************************
   415                              .public			B_SDA_1
   416 0000F0AF                     B_SDA_1:	;Set SDA output H
   417 0000F0AF A5 C2               		LDA		P_IOD_DIR_Map
   418 0000F0B1 09 10               		ORA		#I2C_SDA
   419 0000F0B3 85 C2               		STA		P_IOD_DIR_Map
   420 0000F0B5 85 11               		STA		P_IO_PortD_Dir
   421 0000F0B7 A5 C4               		LDA		R_PortD_Data_Buf
   422 0000F0B9 09 10               		ORA		#I2C_SDA
   423 0000F0BB 85 C4               		STA		R_PortD_Data_Buf
   424 0000F0BD 85 13               		STA		P_IO_PortD_Data
   425 0000F0BF 60                  			RTS	
   426                              ;***************************************			
   427 0000F0C0                     B_SCL_0:	;Set SCL output L
   428 0000F0C0 A5 C2               		LDA		P_IOD_DIR_Map
