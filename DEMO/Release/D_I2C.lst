   531                              ;=========================================================
   532                              .PUBLIC	F_IIC_Set8bit			
   533                              ;****************************************	
   534 0000F152                     F_IIC_Set8bit:	; Y = input 8bit data value	
   535 0000F152 20 C0 F0            		JSR		B_SCL_0
   536 0000F155 20 15 F1            		JSR		F_I2C_Delay
   537                              		;X = bit count; Y = be write byte
   538 0000F158 A2 08               		LDX		#8
   539 0000F15A                     	?loop:	
   540 0000F15A 98                  		TYA               ; 珂參Y樓婥善Aㄛ祥党蜊Y
   541 0000F15B 29 80               		AND		#0x80        ; 枑龰郔詢弇ㄗ0x80=10000000Bㄘ
   542 0000F15D F0 06               		BEQ		?set_0       ; 郔詢弇峈0 ↙ 楷0
   543 0000F15F                     	?set_1:	
   544 0000F15F 20 AF F0            		JSR		B_SDA_1		
   545 0000F162 4C 68 F1            		JMP		?next
   546 0000F165                     	?set_0:
   547 0000F165 20 9E F0            		JSR		B_SDA_0
   548 0000F168                     	?next:	
   549 0000F168 20 15 F1            		JSR		F_I2C_Delay
   550 0000F16B 20 D1 F0            		JSR		B_SCL_1
   551 0000F16E 20 15 F1            		JSR		F_I2C_Delay
   552 0000F171 20 C0 F0            		JSR		B_SCL_0
   553 0000F174 20 15 F1            		JSR		F_I2C_Delay
   554                              		; 痄弇紱釬溫婓郔綴ㄗ瓚剿俇婬痄弇ㄘ
   555 0000F177 98                  		TYA
   556 0000F178 0A                  		ASL		A			; 酘痄1弇ㄛ袧掘狟珨弇
   557 0000F179 A8                  		TAY	
   558 0000F17A CA                  		DEX		
   559 0000F17B D0 DD               		BNE		?loop	
   560 0000F17D 60                  		RTS	
   561                              ;		TYA
   562                              ;		ASL		A			;植詢善腴羲宎換
   563                              ;	;	LSR		A			;植腴善詢羲宎換
   564                              ;		TAY	
   565                              ;		BCS		?set_1
   566                              ;	?set_0:
   567                              ;		JSR		B_SDA_0
   568                              ;		JMP		?next
   569                              ;	?set_1:	
   570                              ;		JSR		B_SDA_1		
   571                              ;	?next:	
   572                              ;		JSR		F_I2C_Delay
   573                              ;		JSR		B_SCL_1
   574                              ;		JSR		F_I2C_Delay
   575                              ;		JSR		B_SCL_0
   576                              ;		JSR		F_I2C_Delay
   577                              ;		DEX		
   578                              ;		BNE		?loop	
   579                              ;			RTS
