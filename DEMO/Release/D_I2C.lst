   613                              .PUBLIC	F_ACK	;楷冞ACK
   614                              ;****************************************			
   615 0000F1A7                     F_ACK:	;Check ACK & Send ACK [[no check ACK but only wait one scycle]]
   616 0000F1A7 20 9E F0            		JSR		B_SDA_0
   617 0000F1AA 20 15 F1            		JSR		F_I2C_Delay
   618 0000F1AD 20 D1 F0            		JSR		B_SCL_1
   619 0000F1B0 20 15 F1            		JSR		F_I2C_Delay
   620 0000F1B3 20 C0 F0            		JSR		B_SCL_0
   621 0000F1B6 20 15 F1            		JSR		F_I2C_Delay
   622 0000F1B9 20 15 F1            		JSR		F_I2C_Delay
   623 0000F1BC 60                  			RTS	
   624                              ;=========================================================
   625                              .PUBLIC	F_RACK  ;諉彶ACK
   626                              ;****************************************						
   627 0000F1BD                     F_RACK:
   628 0000F1BD 20 04 F1            		JSR		B_SDA_F
   629 0000F1C0 20 15 F1            		JSR		F_I2C_Delay	
   630                              		;------------------------
   631 0000F1C3 A9 00               		LDA		#0		
   632 0000F1C5 85 CD               		STA		R_ACK_Err
   633 0000F1C7 85 CC               		STA		R_ACK_Timeout	
   634 0000F1C9 20 D1 F0            		JSR		B_SCL_1
   635 0000F1CC 20 15 F1            		JSR		F_I2C_Delay
   636 0000F1CF                     	?wait:	
   637 0000F1CF A9 00               		LDA		#00
   638 0000F1D1 85 0F               	   STA	   P_WDT_Flag_Clear
   639                              
   640 0000F1D3 E6 CC               		INC		R_ACK_Timeout
   641                              		
   642 0000F1D5 A5 CC               		LDA		R_ACK_Timeout
   643 0000F1D7 C9 80               		CMP		#0x80			; 閉奀蓒硉ㄗ褫覃淕ㄛ⺼0x80＞1msㄛ剒⑤饜斕腔F_I2C_Delay奀酗ㄘ
   644 0000F1D9 B0 14               		BCS		?ACK_Timeout
   645                              		
   646 0000F1DB A5 13               		LDA		P_I2C_Dat	
   647 0000F1DD 29 10               		AND		#I2C_SDA
   648 0000F1DF D0 EE               		BNE		?wait
   649                              		
   650                              	;	BNE		?FailRACK
   651 0000F1E1 20 C0 F0            		JSR		B_SCL_0
   652 0000F1E4 20 15 F1            		JSR		F_I2C_Delay
   653 0000F1E7 20 15 F1            		JSR		F_I2C_Delay
   654                              		;扢离SDA output	low,
   655 0000F1EA 20 9E F0            		JSR		B_SDA_0
   656 0000F1ED 38                  		SEC				; ACK received
   657 0000F1EE 60                  		RTS
   658 0000F1EF                     	?ACK_Timeout:
   659 0000F1EF A9 01               		LDA		#0x01	
   660 0000F1F1 85 CD               		STA		R_ACK_Err
   661 0000F1F3 20 C0 F0            		JSR		B_SCL_0
   662 0000F1F6 20 15 F1            		JSR		F_I2C_Delay
   663 0000F1F9 20 15 F1            		JSR		F_I2C_Delay
   664 0000F1FC 20 9E F0            		JSR		B_SDA_0
   665 0000F1FF 18                  		CLC				; ACK timeout / NAK
   666 0000F200 60                  		RTS
   667                              
