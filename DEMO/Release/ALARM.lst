  2077 0000F692 29 80                   AND     #80H
  2078 0000F694 F0 34                   BEQ     TrendTempLtMin_True
  2079 0000F696 AD 86 01                LDA     R_TempCH
  2080 0000F699 CD BB 01                CMP     R_TrendTempMinH
  2081 0000F69C 90 2A                   BCC     TrendTempLtMin_False
  2082 0000F69E D0 2A                   BNE     TrendTempLtMin_True
  2083 0000F6A0 AD 87 01                LDA     R_TempCL
