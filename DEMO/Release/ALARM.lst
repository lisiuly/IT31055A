  2412 0000F885 4C 92 F8                JMP		F_HistoryClearRecord
  2413                              
  2414                              ; 函数: F_HistoryClearPrev
  2415                              ; 作用: 选择 Previous Day 记录并跳到通用清空逻辑。
  2416 0000F888                     F_HistoryClearPrev:
  2417 0000F888 A2 16                   LDX		#C_HisRecPrev
  2418 0000F88A 4C 92 F8                JMP		F_HistoryClearRecord
  2419                              
  2420                              ; 函数: F_HistoryClearAll
  2421                              ; 作用: 选择 All-time 记录并跳到通用清空逻辑。
  2422 0000F88D                     F_HistoryClearAll:
  2423 0000F88D A2 21                   LDX		#C_HisRecAll
  2424 0000F88F 4C 92 F8                JMP		F_HistoryClearRecord
  2425                              
  2426                              ;-------------------------------------------------------
  2427                              ; 函数: F_HistoryClearRecord
  2428                              ; 作用: 按 X 指向的记录起始偏移，把整条 history record 清零。
  2429                              ; 输入: X = C_HisRecToday / C_HisRec48Today / C_HisRecPrev / C_HisRecAll。
  2430                              ; 输出: 该 record 的 flags、温度、华氏、湿度最大最小值全部清零。
  2431                              ; 说明: 这里正是为什么偏移量必须按 11 字节步长递增；否则清零会落到别的字段上。
  2432 0000F892                     F_HistoryClearRecord:
  2433 0000F892 A9 00                   LDA     #00H
  2434 0000F894 9D 8A 01                STA     R_TodayRecFlags,X        ; Flags
  2435 0000F897 9D 8B 01                STA     R_TodayRecTempMax,X      ; TempMax 低字节
  2436 0000F89A 9D 8C 01                STA     R_TodayRecTempMax+1,X    ; TempMax 高字节
  2437 0000F89D 9D 8D 01                STA     R_TodayRecTempMaxF,X     ; TempMaxF 低字节
  2438 0000F8A0 9D 8E 01                STA     R_TodayRecTempMaxF+1,X   ; TempMaxF 高字节
  2439 0000F8A3 9D 8F 01                STA     R_TodayRecTempMin,X      ; TempMin 低字节
  2440 0000F8A6 9D 90 01                STA     R_TodayRecTempMin+1,X    ; TempMin 高字节
  2441 0000F8A9 9D 91 01                STA     R_TodayRecTempMinF,X     ; TempMinF 低字节
  2442 0000F8AC 9D 92 01                STA     R_TodayRecTempMinF+1,X   ; TempMinF 高字节
  2443 0000F8AF 9D 93 01                STA     R_TodayRecHumMax,X       ; HumMax
  2444 0000F8B2 9D 94 01                STA     R_TodayRecHumMin,X       ; HumMin
  2445 0000F8B5 60                      RTS
  2446                              ;    LDA		#00H
  2447                              ;    STA		R_TodayRecFlags,X
  2448                              ;    STA		R_TodayRecTempMax,X
  2449                              ;    
  2450                              ;    STA		R_TodayRecTempMaxF,X
  2451                              ;
  2452                              ;    STA		R_TodayRecTempMin,X
  2453                              ;
  2454                              ;    STA		R_TodayRecTempMinF,X
  2455                              ;    
  2456                              ;    STA		R_TodayRecHumMax,X
  2457                              ;    STA		R_TodayRecHumMin,X
  2458                              ;    RTS
  2459                              
  2460                              ; Previous Day 只在跨日时整体接管独立 48Hr 今天桶的上一日结果，
  2461                              ; 这里保留完整的 C/F/湿度记录，避免显示时再做额外换算。
  2462                              ; 函数: F_HistoryCopy48TodayToPrev
  2463                              ; 作用: 跨日时把“昨天结束时的 48HrToday 桶”整体复制到 Previous Day。
  2464 0000F8B6                     F_HistoryCopy48TodayToPrev:
  2465 0000F8B6 A2 0B                   LDX		#C_HisRec48Today
  2466 0000F8B8 A0 16                   LDY		#C_HisRecPrev
  2467 0000F8BA 4C BD F8                JMP		F_HistoryCopyRecord
  2468                              
  2469                              ;-------------------------------------------------------
  2470                              ; 函数: F_HistoryCopyRecord
  2471                              ; 作用: 把 X 指向的整条 history record 拷贝到 Y 指向的另一条 record。
  2472                              ; 输入: X = 源记录偏移，Y = 目标记录偏移。
  2473                              ; 输出: 目标记录被完整覆盖。
  2474                              ; 说明: 复制时按字段顺序逐项搬运，而不是按裸内存块复制，方便后续结构扩展时逐项维护。
  2475 0000F8BD                     F_HistoryCopyRecord:
  2476                                  ; Flags
  2477 0000F8BD BD 8A 01                LDA     R_TodayRecFlags,X
  2478 0000F8C0 99 8A 01                STA     R_TodayRecFlags,Y
  2479                                  ; TempMax 2 字节
  2480 0000F8C3 BD 8B 01                LDA     R_TodayRecTempMax,X
  2481 0000F8C6 99 8B 01                STA     R_TodayRecTempMax,Y
  2482 0000F8C9 BD 8C 01                LDA     R_TodayRecTempMax+1,X
  2483 0000F8CC 99 8C 01                STA     R_TodayRecTempMax+1,Y
  2484                                  ; TempMaxF 2 字节
  2485 0000F8CF BD 8D 01                LDA     R_TodayRecTempMaxF,X
  2486 0000F8D2 99 8D 01                STA     R_TodayRecTempMaxF,Y
  2487 0000F8D5 BD 8E 01                LDA     R_TodayRecTempMaxF+1,X
  2488 0000F8D8 99 8E 01                STA     R_TodayRecTempMaxF+1,Y
  2489                                  ; TempMin 2 字节
  2490 0000F8DB BD 8F 01                LDA     R_TodayRecTempMin,X
  2491 0000F8DE 99 8F 01                STA     R_TodayRecTempMin,Y
  2492 0000F8E1 BD 90 01                LDA     R_TodayRecTempMin+1,X
  2493 0000F8E4 99 90 01                STA     R_TodayRecTempMin+1,Y
  2494                                  ; TempMinF 2 字节
  2495 0000F8E7 BD 91 01                LDA     R_TodayRecTempMinF,X
  2496 0000F8EA 99 91 01                STA     R_TodayRecTempMinF,Y
  2497 0000F8ED BD 92 01                LDA     R_TodayRecTempMinF+1,X
  2498 0000F8F0 99 92 01                STA     R_TodayRecTempMinF+1,Y
  2499                                  ; HumMax
  2500 0000F8F3 BD 93 01                LDA     R_TodayRecHumMax,X
  2501 0000F8F6 99 93 01                STA     R_TodayRecHumMax,Y
  2502                                  ; HumMin
  2503 0000F8F9 BD 94 01                LDA     R_TodayRecHumMin,X
  2504 0000F8FC 99 94 01                STA     R_TodayRecHumMin,Y
  2505 0000F8FF 60                      RTS
  2506                              
  2507                              ; 函数: F_HistorySeedTodayFromCurrent
  2508                              ; 作用: 用当前采样值初始化 Today 记录。
  2509 0000F900                     F_HistorySeedTodayFromCurrent:
  2510 0000F900 A2 00                   LDX		#C_HisRecToday
  2511 0000F902 4C 0F F9                JMP		F_HistorySeedRecordFromCurrent
  2512                              
  2513                              ; 函数: F_HistorySeed48TodayFromCurrent
  2514                              ; 作用: 用当前采样值初始化 48HrToday 记录。
  2515 0000F905                     F_HistorySeed48TodayFromCurrent:
  2516 0000F905 A2 0B                   LDX		#C_HisRec48Today
  2517 0000F907 4C 0F F9                JMP		F_HistorySeedRecordFromCurrent
  2518                              
  2519                              ; 函数: F_HistorySeedAllFromCurrent
  2520                              ; 作用: 用当前采样值初始化 All-time 记录。
  2521 0000F90A                     F_HistorySeedAllFromCurrent:
  2522 0000F90A A2 21                   LDX		#C_HisRecAll
  2523 0000F90C 4C 0F F9                JMP		F_HistorySeedRecordFromCurrent
  2524                              
  2525                              ;-------------------------------------------------------
  2526                              ; 函数: F_HistorySeedRecordFromCurrent
  2527                              ; 作用: 用当前样本覆盖指定 record；湿度始终写入，温度只在量程内时写入。
  2528                              ; 输入: X = 目标记录偏移，当前温湿度显示值与温度符号位。
  2529                              ; 输出: 指定 record 至少带当前湿度；若温度在量程内，temp max/min 也被初始化。
  2530                              ; 说明: 第一次采样时最大值和最小值都等于当前值，所以 max/min 两套字段都会写同一份数据。
  2531 0000F90F                     F_HistorySeedRecordFromCurrent:
  2532 0000F90F A9 01                   LDA     #D_HisValid
  2533 0000F911 9D 8A 01                STA     R_TodayRecFlags,X
  2534 0000F914 AD D2 01                LDA     R_DispHum
  2535 0000F917 9D 93 01                STA     R_TodayRecHumMax,X
  2536 0000F91A 9D 94 01                STA     R_TodayRecHumMin,X
  2537 0000F91D 20 6A F4            	JSR		F_IsCurrentTempInRange
  2538 0000F920 90 03               	BCC		HistorySeedRecord_Exit
  2539 0000F922 4C 26 F9                JMP     HistorySeedRecord_SeedTempFromCurrent
  2540                              
  2541 0000F925                     HistorySeedRecord_Exit:
  2542 0000F925 60                      RTS
  2543                              
  2544 0000F926                     HistorySeedRecord_SeedTempFromCurrent:
  2545 0000F926 BD 8A 01                LDA     R_TodayRecFlags,X
  2546 0000F929 29 7F                   AND     #.not.D_HisMaxNeg
  2547 0000F92B 29 BF                   AND     #.not.D_HisMinNeg
  2548 0000F92D 09 02                   ORA     #D_HisTempValid
  2549 0000F92F 9D 8A 01                STA     R_TodayRecFlags,X
  2550 0000F932 AD C1 01                LDA     R_SpecFlag
  2551 0000F935 29 10                   AND     #D_Neg
  2552 0000F937 F0 08                   BEQ     HistorySeedRecord_Positive
  2553 0000F939 BD 8A 01                LDA     R_TodayRecFlags,X
  2554 0000F93C 09 C0                   ORA     #(D_HisMaxNeg+D_HisMinNeg)
  2555 0000F93E 9D 8A 01                STA     R_TodayRecFlags,X
  2556 0000F941                     HistorySeedRecord_Positive:
  2557                                  ; 温度 BCD 双字节
  2558 0000F941 AD CC 01                LDA     R_DispTemper+0
  2559 0000F944 9D 8B 01                STA     R_TodayRecTempMax,X
  2560 0000F947 9D 8F 01                STA     R_TodayRecTempMin,X
  2561 0000F94A AD CD 01                LDA     R_DispTemper+1
  2562 0000F94D 9D 8C 01                STA     R_TodayRecTempMax+1,X
  2563 0000F950 9D 90 01                STA     R_TodayRecTempMin+1,X
  2564                                  ; 华氏度 BCD 双字节
  2565 0000F953 AD C6 01                LDA     R_DispTemper_F+0
  2566 0000F956 9D 8D 01                STA     R_TodayRecTempMaxF,X
  2567 0000F959 9D 91 01                STA     R_TodayRecTempMinF,X
  2568 0000F95C AD C7 01                LDA     R_DispTemper_F+1
  2569 0000F95F 9D 8E 01                STA     R_TodayRecTempMaxF+1,X
  2570 0000F962 9D 92 01                STA     R_TodayRecTempMinF+1,X
  2571 0000F965 60                      RTS
