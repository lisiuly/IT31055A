  2177                              ; 函数: F_UpdateHumTrendState
  2178                              ; 作用: 按湿度窗口 max/min 的扩张方向判定 Up/Down；若未触发则累计湿度计数。
  2179 0000F729                     F_UpdateHumTrendState:
  2180 0000F729 AD 88 01                LDA     R_HUM
  2181 0000F72C CD BD 01                CMP     R_TrendHumMax
  2182 0000F72F 90 15                   BCC     TrendHum_CheckMin
  2183 0000F731 F0 13                   BEQ     TrendHum_CheckMin
  2184 0000F733 8D BD 01                STA     R_TrendHumMax
  2185 0000F736 20 7B F7                JSR     F_TrendHumSpanReached
  2186 0000F739 90 26                   BCC     TrendHum_StepCount
  2187 0000F73B AD B8 01                LDA     R_TrendFlags
  2188 0000F73E 09 48                   ORA     #(D_HumTrendUp+D_HumTrendRefresh)
  2189 0000F740 8D B8 01                STA     R_TrendFlags
  2190 0000F743 4C D9 F5                JMP     F_TrendResetHumWindowCurrent
  2191                              
  2192 0000F746                     TrendHum_CheckMin:
  2193 0000F746 AD 88 01                LDA     R_HUM
  2194 0000F749 CD BE 01                CMP     R_TrendHumMin
  2195 0000F74C B0 13                   BCS     TrendHum_StepCount
  2196 0000F74E 8D BE 01                STA     R_TrendHumMin
  2197 0000F751 20 7B F7                JSR     F_TrendHumSpanReached
  2198 0000F754 90 0B                   BCC     TrendHum_StepCount
  2199 0000F756 AD B8 01                LDA     R_TrendFlags
  2200 0000F759 09 50                   ORA     #(D_HumTrendDown+D_HumTrendRefresh)
  2201 0000F75B 8D B8 01                STA     R_TrendFlags
  2202 0000F75E 4C D9 F5                JMP     F_TrendResetHumWindowCurrent
  2203                              
  2204 0000F761                     TrendHum_StepCount:
  2205 0000F761 AD C0 01                LDA     R_TrendHumEqCnt
  2206 0000F764 C9 3C                   CMP     #C_TrendEq60Min
  2207 0000F766 B0 12                   BCS     TrendHum_Exit
  2208 0000F768 EE C0 01                INC     R_TrendHumEqCnt
  2209 0000F76B AD C0 01                LDA     R_TrendHumEqCnt
  2210 0000F76E C9 3C                   CMP     #C_TrendEq60Min
  2211 0000F770 D0 08                   BNE     TrendHum_Exit
  2212 0000F772 AD B8 01                LDA     R_TrendFlags
  2213 0000F775 09 40                   ORA     #D_HumTrendRefresh
  2214 0000F777 8D B8 01                STA     R_TrendFlags
  2215 0000F77A                     TrendHum_Exit:
  2216 0000F77A 60                      RTS
