  2742 0000FA9E BD 8A 01                LDA		R_TodayRecFlags,X
  2743 0000FAA1 09 41                   ORA		#(D_HisValid+D_HisMinNeg)
  2744 0000FAA3 9D 8A 01                STA		R_TodayRecFlags,X
  2745                              
