  2591                              ;-------------------------------------------------------
  2592                              ; 函数: F_HistoryUpdateRecordFromCurrent
  2593                              ; 作用: 把当前样本并入指定 record，按规则更新温度/湿度最大最小值。
  2594                              ; 输入: X = 目标记录偏移，当前温湿度显示值、当前温度正负标志。
  2595                              ; 输出: 目标 record 内的 max/min 字段和正负号标志可能被刷新。
  2596                              ; 说明: 温度比较仍需区分正温和负温；湿度则直接按无符号大小更新。
  2597 0000F975                     F_HistoryUpdateRecordFromCurrent:
  2598 0000F975 BD 8A 01                LDA		R_TodayRecFlags,X
  2599 0000F978 29 01                   AND		#D_HisValid
  2600 0000F97A D0 03                   BNE		HistoryUpdateRecord_SeedContinue
  2601 0000F97C 4C 0F F9                JMP		F_HistorySeedRecordFromCurrent
  2602 0000F97F                     HistoryUpdateRecord_SeedContinue:
  2603 0000F97F 20 6A F4            	JSR		F_IsCurrentTempInRange
  2604 0000F982 B0 03                   BCS		HistoryUpdateRecord_CheckTempRange
  2605 0000F984 4C A6 FA                JMP		HistoryUpdateRecord_CheckHum
  2606 0000F987                     HistoryUpdateRecord_CheckTempRange:
  2607 0000F987 BD 8A 01                LDA		R_TodayRecFlags,X
  2608 0000F98A 29 02                   AND		#D_HisTempValid
  2609 0000F98C F0 03                   BEQ		HistoryUpdateRecord_SeedTempOnly
  2610 0000F98E 4C 97 F9                JMP		HistoryUpdateRecord_CheckTemp
  2611 0000F991                     HistoryUpdateRecord_SeedTempOnly:
  2612 0000F991 20 26 F9                JSR		HistorySeedRecord_SeedTempFromCurrent
  2613 0000F994 4C A6 FA                JMP		HistoryUpdateRecord_CheckHum
  2614                              
  2615 0000F997                     HistoryUpdateRecord_CheckTemp:
  2616                              
  2617 0000F997 AD C1 01                LDA		R_SpecFlag
  2618 0000F99A 29 10                   AND		#D_Neg
  2619 0000F99C F0 03                   BEQ		HistoryUpdateRecord_MaxPosPath
  2620 0000F99E 4C E4 F9                JMP		HistoryUpdateRecord_MaxNeg
  2621 0000F9A1                     HistoryUpdateRecord_MaxPosPath:
  2622 0000F9A1 BD 8A 01                LDA		R_TodayRecFlags,X
  2623 0000F9A4 29 80                   AND		#D_HisMaxNeg
  2624 0000F9A6 D0 14                   BNE		HistoryUpdateRecord_UpdateMaxPosJump
  2625 0000F9A8 AD CC 01                LDA		R_DispTemper+0
  2626 0000F9AB DD 8B 01                CMP		R_TodayRecTempMax,X
  2627 0000F9AE 90 70                   BCC		HistoryUpdateRecord_CheckMin
  2628 0000F9B0 D0 0A                   BNE		HistoryUpdateRecord_UpdateMaxPosJump
  2629 0000F9B2 AD CD 01                LDA		R_DispTemper+1
  2630 0000F9B5 DD 8C 01                CMP		R_TodayRecTempMax+1,X
  2631 0000F9B8 90 66                   BCC		HistoryUpdateRecord_CheckMin
  2632 0000F9BA F0 64                   BEQ		HistoryUpdateRecord_CheckMin
  2633 0000F9BC                     HistoryUpdateRecord_UpdateMaxPosJump:
  2634 0000F9BC 4C BF F9                JMP		HistoryUpdateRecord_UpdateMaxPos
  2635 0000F9BF                     HistoryUpdateRecord_UpdateMaxPos:
  2636                              ;     LDA		R_DispTemper+0
  2637                              ; ;    STA		R_TodayRecTempMax,X
  2638                              ;     STA		R_TodayRecTempMax+0
  2639                              ;     LDA		R_DispTemper+1
  2640                              ;     STA		R_TodayRecTempMax+1
  2641                                  
  2642                              ;     LDA		R_DispTemper_F+0
  2643                              ; ;    STA		R_TodayRecTempMaxF0,X
  2644                              ;     STA		R_TodayRecTempMaxF+0
  2645                              ;     LDA		R_DispTemper_F+1
  2646                              ;     STA		R_TodayRecTempMaxF+1
  2647                              ; ;    STA		R_TodayRecTempMaxF1,X
  2648 0000F9BF AD CC 01                LDA     R_DispTemper+0
  2649 0000F9C2 9D 8B 01                STA     R_TodayRecTempMax,X     ; 用 X 索引
  2650 0000F9C5 AD CD 01                LDA     R_DispTemper+1
  2651 0000F9C8 9D 8C 01                STA     R_TodayRecTempMax+1,X   ; 高字节
  2652 0000F9CB AD C6 01                LDA     R_DispTemper_F+0
  2653 0000F9CE 9D 8D 01                STA     R_TodayRecTempMaxF,X
  2654 0000F9D1 AD C7 01                LDA     R_DispTemper_F+1
  2655 0000F9D4 9D 8E 01                STA     R_TodayRecTempMaxF+1,X
  2656                                      
  2657 0000F9D7 BD 8A 01                LDA		R_TodayRecFlags,X
  2658 0000F9DA 29 7F                   AND		#.not.D_HisMaxNeg
  2659 0000F9DC 09 01                   ORA		#D_HisValid
  2660 0000F9DE 9D 8A 01                STA		R_TodayRecFlags,X
  2661 0000F9E1 4C 20 FA                JMP		HistoryUpdateRecord_CheckMin
  2662                              
  2663 0000F9E4                     HistoryUpdateRecord_MaxNeg:
  2664 0000F9E4 BD 8A 01                LDA		R_TodayRecFlags,X
  2665 0000F9E7 29 80                   AND		#D_HisMaxNeg
  2666 0000F9E9 F0 35                   BEQ		HistoryUpdateRecord_CheckMin
  2667 0000F9EB AD CC 01                LDA		R_DispTemper+0
  2668 0000F9EE DD 8B 01                CMP		R_TodayRecTempMax,X
  2669 0000F9F1 90 0D                   BCC		HistoryUpdateRecord_UpdateMaxNeg
  2670 0000F9F3 D0 2B                   BNE		HistoryUpdateRecord_CheckMin
  2671 0000F9F5 AD CD 01                LDA		R_DispTemper+1
  2672 0000F9F8 DD 8C 01                CMP		R_TodayRecTempMax+1,X
  2673 0000F9FB 90 03                   BCC		HistoryUpdateRecord_UpdateMaxNeg
  2674 0000F9FD 4C 20 FA                JMP		HistoryUpdateRecord_CheckMin
  2675 0000FA00                     HistoryUpdateRecord_UpdateMaxNeg:
  2676 0000FA00 AD CC 01                LDA		R_DispTemper+0
  2677 0000FA03 9D 8B 01                STA		R_TodayRecTempMax,X
  2678 0000FA06 AD CD 01                LDA		R_DispTemper+1
  2679 0000FA09 9D 8C 01                STA		R_TodayRecTempMax+1,X
  2680 0000FA0C AD C6 01                LDA		R_DispTemper_F+0
  2681 0000FA0F 9D 8D 01                STA		R_TodayRecTempMaxF,X
  2682 0000FA12 AD C7 01                LDA		R_DispTemper_F+1
  2683 0000FA15 9D 8E 01                STA		R_TodayRecTempMaxF+1,X
  2684 0000FA18 BD 8A 01                LDA		R_TodayRecFlags,X
  2685 0000FA1B 09 81                   ORA		#(D_HisValid+D_HisMaxNeg)
  2686 0000FA1D 9D 8A 01                STA		R_TodayRecFlags,X
  2687                              
  2688 0000FA20                     HistoryUpdateRecord_CheckMin:
  2689 0000FA20 AD C1 01                LDA		R_SpecFlag
  2690 0000FA23 29 10                   AND		#D_Neg
  2691 0000FA25 F0 03                   BEQ		HistoryUpdateRecord_MinPosPath
  2692 0000FA27 4C 6B FA                JMP		HistoryUpdateRecord_MinNeg
  2693 0000FA2A                     HistoryUpdateRecord_MinPosPath:
  2694 0000FA2A BD 8A 01                LDA		R_TodayRecFlags,X
  2695 0000FA2D 29 40                   AND		#D_HisMinNeg
  2696 0000FA2F D0 75                   BNE		HistoryUpdateRecord_CheckHum
  2697 0000FA31 AD CC 01                LDA		R_DispTemper+0
  2698 0000FA34 DD 8F 01                CMP		R_TodayRecTempMin,X
  2699 0000FA37 90 0D                   BCC		HistoryUpdateRecord_UpdateMinPos
  2700 0000FA39 D0 6B                   BNE		HistoryUpdateRecord_CheckHum
  2701 0000FA3B AD CD 01                LDA		R_DispTemper+1
  2702 0000FA3E DD 90 01                CMP		R_TodayRecTempMin+1,X
  2703 0000FA41 90 03                   BCC		HistoryUpdateRecord_UpdateMinPos
  2704 0000FA43 4C A6 FA                JMP		HistoryUpdateRecord_CheckHum
  2705 0000FA46                     HistoryUpdateRecord_UpdateMinPos:
  2706 0000FA46 AD CC 01                LDA		R_DispTemper+0
  2707 0000FA49 9D 8F 01            	STA		R_TodayRecTempMin,X
  2708 0000FA4C AD CD 01                LDA		R_DispTemper+1
  2709 0000FA4F 9D 90 01            	STA		R_TodayRecTempMin+1,X
  2710                                  
  2711 0000FA52 AD C6 01                LDA		R_DispTemper_F+0
  2712 0000FA55 9D 91 01                STA		R_TodayRecTempMinF,X
  2713 0000FA58 AD C7 01                LDA		R_DispTemper_F+1
  2714 0000FA5B 9D 92 01                STA		R_TodayRecTempMinF+1,X
  2715 0000FA5E BD 8A 01                LDA		R_TodayRecFlags,X
  2716 0000FA61 29 BF                   AND		#.not.D_HisMinNeg
  2717 0000FA63 09 01                   ORA		#D_HisValid
  2718 0000FA65 9D 8A 01                STA		R_TodayRecFlags,X
  2719 0000FA68 4C A6 FA                JMP		HistoryUpdateRecord_CheckHum
  2720                              
  2721 0000FA6B                     HistoryUpdateRecord_MinNeg:
