  1228                              C_HisRecPrev		equ	16H	; 第 3 条记录起点 = 2 * C_HisRecSize
  1229                              C_HisRecAll		equ	21H	; 第 4 条记录起点 = 3 * C_HisRecSize
  1230                              
  1231                              ; 清记录后用 3 秒 dash 覆盖当前记录显示。
