  1210 000001A5 FF FF               R_PrevRecTempMin	ds	2
  1211 000001A7 FF FF               R_PrevRecTempMinF	ds	2
  1212 000001A9 FF                  R_PrevRecHumMax	ds	1
  1213 000001AA FF                  R_PrevRecHumMin	ds	1
