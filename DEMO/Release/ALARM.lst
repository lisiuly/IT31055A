  2736 0000FA8C AD CD 01                LDA		R_DispTemper+1
  2737 0000FA8F 9D 90 01                STA		R_TodayRecTempMin+1,X
  2738 0000FA92 AD C6 01                LDA		R_DispTemper_F+0
