  2086 0000F6A8 F0 1E                   BEQ     TrendTempLtMin_False
  2087 0000F6AA 4C CA F6                JMP     TrendTempLtMin_True
  2088                              
  2089 0000F6AD                     TrendTempLtMin_CurrentPos:
  2090                                  ; 当前温度为正：若最小值已为负，则当前值不可能更小。
  2091 0000F6AD AD BB 01                LDA     R_TrendTempMinH
  2092 0000F6B0 29 80                   AND     #80H
  2093 0000F6B2 D0 14                   BNE     TrendTempLtMin_False
  2094 0000F6B4 AD 86 01                LDA     R_TempCH
  2095 0000F6B7 29 7F                   AND     #7FH
  2096 0000F6B9 CD BB 01                CMP     R_TrendTempMinH
  2097 0000F6BC 90 0C                   BCC     TrendTempLtMin_True
  2098 0000F6BE D0 08                   BNE     TrendTempLtMin_False
  2099 0000F6C0 AD 87 01                LDA     R_TempCL
  2100 0000F6C3 CD BC 01                CMP     R_TrendTempMinL
  2101 0000F6C6 90 02                   BCC     TrendTempLtMin_True
