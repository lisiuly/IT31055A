  2723 0000FA6E 29 40                   AND		#D_HisMinNeg
  2724 0000FA70 F0 14                   BEQ		HistoryUpdateRecord_UpdateMinNeg
  2725 0000FA72 AD CC 01                LDA		R_DispTemper+0
  2726 0000FA75 DD 8F 01                CMP		R_TodayRecTempMin,X
  2727 0000FA78 90 2C                   BCC		HistoryUpdateRecord_CheckHum
