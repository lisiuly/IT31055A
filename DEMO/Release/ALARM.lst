  2235                              ; 每到整分 00 秒，把当前样本并入 Today / 48Hr / All-time，
  2236                              ; 若跨到 00:00:00，则先把独立 48Hr 今天桶滚到 Previous Day。
  2237                              ; 函数: F_HistoryOnSample
  2238                              ; 作用: history 采样主入口，负责首采样初始化、日切换和日内增量更新。
  2239                              ; 输入: RTC 当前时间、当前温湿度显示值、history 初始化标志。
  2240                              ; 输出: Today / 48HrToday / Previous Day / All-time 四套记录中的对应字段。
  2241                              ; 说明: 这套逻辑把“48 小时视图”拆成 48HrToday + Previous Day 两套源数据，显示时再聚合。
  2242 0000F78A                     F_HistoryOnSample:
  2243 0000F78A AD 89 01                LDA		R_HistoryFlags
  2244 0000F78D 29 01                   AND		#D_HistoryInit
  2245 0000F78F D0 14                   BNE		HistorySample_Update
  2246 0000F791 A9 00                   LDA		#00H
  2247 0000F793 8D A0 01                STA		R_PrevRecFlags
  2248 0000F796 20 00 F9                JSR		F_HistorySeedTodayFromCurrent
  2249 0000F799 20 05 F9                JSR		F_HistorySeed48TodayFromCurrent
  2250 0000F79C 20 0A F9                JSR		F_HistorySeedAllFromCurrent
  2251 0000F79F A9 01                   LDA		#D_HistoryInit
  2252 0000F7A1 8D 89 01                STA		R_HistoryFlags
  2253                              
  2254 0000F7A4                     HistorySample_InitSkip:
  2255 0000F7A4 60                      RTS
  2256                              
  2257 0000F7A5                     HistorySample_Update:
  2258 0000F7A5 AD 83 00                LDA		RTC+0
  2259 0000F7A8 D0 1D                   BNE		HistorySample_UpdateToday
  2260 0000F7AA AD 84 00                LDA		RTC+1
  2261 0000F7AD D0 18                   BNE		HistorySample_UpdateToday
  2262 0000F7AF AD 85 00                LDA		RTC+2
  2263 0000F7B2 D0 13                   BNE		HistorySample_UpdateToday
  2264 0000F7B4 AD 95 01                LDA		R_48TodayRecFlags
  2265 0000F7B7 29 01                   AND		#D_HisValid
  2266 0000F7B9 F0 03                   BEQ		HistorySample_ResetToday
  2267 0000F7BB 20 B6 F8                JSR		F_HistoryCopy48TodayToPrev
  2268 0000F7BE                     HistorySample_ResetToday:
  2269 0000F7BE 20 00 F9                JSR		F_HistorySeedTodayFromCurrent
  2270 0000F7C1 20 05 F9                JSR		F_HistorySeed48TodayFromCurrent
  2271 0000F7C4 4C 70 F9                JMP		F_HistoryUpdateAllFromCurrent
  2272                              
  2273 0000F7C7                     HistorySample_UpdateToday:
  2274 0000F7C7 20 66 F9                JSR		F_HistoryUpdateTodayFromCurrent
  2275 0000F7CA 20 6B F9                JSR		F_HistoryUpdate48TodayFromCurrent
  2276 0000F7CD 4C 70 F9                JMP		F_HistoryUpdateAllFromCurrent
  2277                              
  2278                              ;-------------------------------------------------------
  2279                              ; 函数: F_LoadHistoryViewBuffers
  2280                              ; 作用: 根据当前页面状态，把指定 history 记录装入旧显示兼容缓冲。
  2281                              ; 输入: R_ProductPage、R_HistoryPage、history valid 标志。
  2282                              ; 输出: R_TempMax/R_TempMin/R_HumMax/R_HumMin 以及对应符号/华氏缓存。
  2283                              ; 说明: LCD 层仍复用旧 max/min 渲染链，所以这里要把新 history 结构整理回兼容缓冲。
  2284 0000F7D0                     F_LoadHistoryViewBuffers:
  2285 0000F7D0 A9 00               	LDA		#00H
  2286 0000F7D2 8D B7 01            	STA		R_HistoryViewFlags
  2287 0000F7D5 AD 89 01                LDA		R_HistoryFlags
  2288 0000F7D8 29 01                   AND		#D_HistoryInit
  2289 0000F7DA D0 03                   BNE		HistoryLoadView_Select
  2290 0000F7DC 4C 77 FB                JMP		F_HistoryClearCompat
  2291                              
  2292 0000F7DF                     HistoryLoadView_Select:
  2293 0000F7DF AD 9F 00                LDA		R_ProductPage
  2294 0000F7E2 C9 02                   CMP		#D_PageHistory
  2295 0000F7E4 F0 03                   BEQ		HistoryLoadView_PageHistory
  2296 0000F7E6 4C C3 FA                JMP		F_HistoryLoadTodayToCompat
  2297                              
  2298 0000F7E9                     HistoryLoadView_PageHistory:
  2299 0000F7E9 AD A0 00                LDA		R_HistoryPage
  2300 0000F7EC C9 02                   CMP		#D_His48Hr
  2301 0000F7EE F0 0A                   BEQ		HistoryLoadView_48Hr
  2302 0000F7F0 C9 04                   CMP		#D_HisAllTm
  2303 0000F7F2 F0 03                   BEQ		HistoryLoadView_All
  2304 0000F7F4 4C C3 FA                JMP		F_HistoryLoadTodayToCompat
  2305                              
  2306 0000F7F7                     HistoryLoadView_All:
  2307 0000F7F7 4C CD FA                JMP		F_HistoryLoadAllToCompat
  2308                              
  2309 0000F7FA                     HistoryLoadView_48Hr:
  2310 0000F7FA AD 95 01                LDA		R_48TodayRecFlags
  2311 0000F7FD 29 01                   AND		#D_HisValid
  2312 0000F7FF F0 0D                   BEQ		HistoryLoadView_48HrSeedFromPrev
  2313 0000F801 20 C8 FA                JSR		F_HistoryLoad48TodayToCompat
  2314 0000F804 AD A0 01                LDA		R_PrevRecFlags
  2315 0000F807 29 01                   AND		#D_HisValid
  2316 0000F809 F0 10                   BEQ		HistoryLoadView_48HrDone
  2317 0000F80B 4C 86 FB                JMP		F_HistoryMergePrevIntoCompat
  2318 0000F80E                     HistoryLoadView_48HrSeedFromPrev:
  2319 0000F80E AD A0 01                LDA		R_PrevRecFlags
  2320 0000F811 29 01                   AND		#D_HisValid
  2321 0000F813 F0 03                   BEQ		HistoryLoadView_48HrClear
  2322 0000F815 4C D2 FA                JMP		F_HistoryLoadPrevToCompat
  2323 0000F818                     HistoryLoadView_48HrClear:
  2324 0000F818 4C 77 FB                JMP		F_HistoryClearCompat
  2325 0000F81B                     HistoryLoadView_48HrDone:
  2326 0000F81B 60                      RTS
  2327                              
  2328                              ;-------------------------------------------------------
  2329                              ; 函数: F_ClearCurrentHistory
  2330                              ; 作用: 按当前所在页面清除对应 history 记录，并启动 3 秒清除反馈显示。
  2331                              ; 输入: R_ProductPage、R_HistoryPage。
  2332                              ; 输出: 对应记录被清零，R_HistoryClearTm 被装载，兼容缓冲重载。
  2333                              ; 说明: Today、48Hr、All-time 的清理范围不同；48Hr 会同时清 48HrToday 和 Previous Day 两个源桶。
  2334 0000F81C                     F_ClearCurrentHistory:
  2335 0000F81C AD 9F 00                LDA		R_ProductPage
  2336 0000F81F C9 02                   CMP		#D_PageHistory
  2337 0000F821 F0 09                   BEQ		HistoryClear_SelectCurrentPage
  2338 0000F823 20 7E F8                JSR		F_HistoryClearToday
  2339 0000F826 20 5A F8            	JSR		F_HistoryReseedTodayFromCurrent
  2340 0000F829 4C 52 F8                JMP		HistoryClear_StartFeedback
  2341                              
  2342 0000F82C                     HistoryClear_SelectCurrentPage:
  2343 0000F82C AD A0 00                LDA		R_HistoryPage
  2344 0000F82F C9 02                   CMP		#D_His48Hr
  2345 0000F831 F0 0D                   BEQ		HistoryClear_48Hr
  2346 0000F833 C9 04                   CMP		#D_HisAllTm
  2347 0000F835 F0 15                   BEQ		HistoryClear_All
  2348 0000F837 20 7E F8                JSR		F_HistoryClearToday
  2349 0000F83A 20 5A F8            	JSR		F_HistoryReseedTodayFromCurrent
  2350 0000F83D 4C 52 F8                JMP		HistoryClear_StartFeedback
  2351                              
  2352                              ; 48hr 当前仍由 Today + Previous Day 聚合，清除时同步清掉两套来源记录。
  2353 0000F840                     HistoryClear_48Hr:
  2354 0000F840 20 83 F8                JSR		F_HistoryClear48Today
  2355 0000F843 20 88 F8                JSR		F_HistoryClearPrev
  2356 0000F846 20 66 F8            	JSR		F_HistoryReseed48TodayFromCurrent
  2357 0000F849 4C 52 F8                JMP		HistoryClear_StartFeedback
  2358                              
  2359 0000F84C                     HistoryClear_All:
  2360 0000F84C 20 8D F8                JSR		F_HistoryClearAll
  2361 0000F84F 20 72 F8            	JSR		F_HistoryReseedAllFromCurrent
  2362                              
  2363 0000F852                     HistoryClear_StartFeedback:
  2364 0000F852 A9 06                   LDA		#C_HistoryClear3Sec
  2365 0000F854 8D B6 01                STA		R_HistoryClearTm
  2366 0000F857 4C D0 F7                JMP		F_LoadHistoryViewBuffers
  2367                              
  2368                              ; 函数: F_HistoryReseedTodayFromCurrent
  2369                              ; 作用: 清除反馈期间，后台用当前样本重建 Today 记录。
  2370                              ; 说明: 前台仍会先显示 3 秒横杠，倒计时结束后即可直接恢复为当前刷新数据。
  2371 0000F85A                     F_HistoryReseedTodayFromCurrent:
  2372                              	%bits	R_HistoryFlags,D_HistoryInit
  2373 0000F85A AD 89 01          1           lda     R_HistoryFlags               ;ex.  
  2374 0000F85D 09 01             1           ora     #D_HistoryInit              ;  %bits 10H,_BIT0
  2375                            1 		                   ;  10H.0=1
  2376 0000F85F 8D 89 01          1           sta     R_HistoryFlags               ;
  2377 0000F862 20 00 F9            	JSR		F_HistorySeedTodayFromCurrent
  2378 0000F865 60                  	RTS
  2379                              
  2380                              ; 函数: F_HistoryReseed48TodayFromCurrent
  2381                              ; 作用: 清除 48hr 后，用当前样本重建独立 48HrToday 桶。
  2382 0000F866                     F_HistoryReseed48TodayFromCurrent:
