  1249 000001BB FF                  R_TrendTempMinH	ds	1
  1250 000001BC FF                  R_TrendTempMinL	ds	1
  1251 000001BD FF                  R_TrendHumMax	ds	1
  1252 000001BE FF                  R_TrendHumMin	ds	1
