  2384 0000F866 AD 89 01          1           lda     R_HistoryFlags               ;ex.  
  2385 0000F869 09 01             1           ora     #D_HistoryInit              ;  %bits 10H,_BIT0
  2386                            1 		                   ;  10H.0=1
  2387 0000F86B 8D 89 01          1           sta     R_HistoryFlags               ;
  2388 0000F86E 20 05 F9            	JSR		F_HistorySeed48TodayFromCurrent
  2389 0000F871 60                  	RTS
  2390                              
  2391                              ; 函数: F_HistoryReseedAllFromCurrent
  2392                              ; 作用: 清除 all-time 后，用当前样本重建 all-time 记录。
  2393 0000F872                     F_HistoryReseedAllFromCurrent:
  2394                              	%bits	R_HistoryFlags,D_HistoryInit
  2395 0000F872 AD 89 01          1           lda     R_HistoryFlags               ;ex.  
  2396 0000F875 09 01             1           ora     #D_HistoryInit              ;  %bits 10H,_BIT0
  2397                            1 		                   ;  10H.0=1
  2398 0000F877 8D 89 01          1           sta     R_HistoryFlags               ;
  2399 0000F87A 20 0A F9            	JSR		F_HistorySeedAllFromCurrent
  2400 0000F87D 60                  	RTS
  2401                              
  2402                              ; 函数: F_HistoryClearToday
  2403                              ; 作用: 选择 Today 记录并跳到通用清空逻辑。
  2404 0000F87E                     F_HistoryClearToday:
