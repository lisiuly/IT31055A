  2045 0000F667 AD B9 01                LDA     R_TrendTempMaxH
  2046 0000F66A 29 80                   AND     #80H
  2047 0000F66C D0 16                   BNE     TrendTempGtMax_True
  2048 0000F66E AD 86 01                LDA     R_TempCH
  2049 0000F671 29 7F                   AND     #7FH
  2050 0000F673 CD B9 01                CMP     R_TrendTempMaxH
  2051 0000F676 90 0E                   BCC     TrendTempGtMax_False
  2052 0000F678 D0 0A                   BNE     TrendTempGtMax_True
  2053 0000F67A AD 87 01                LDA     R_TempCL
  2054 0000F67D CD BA 01                CMP     R_TrendTempMaxL
  2055 0000F680 90 04                   BCC     TrendTempGtMax_False
  2056 0000F682 F0 02                   BEQ     TrendTempGtMax_False
  2057                              
  2058 0000F684                     TrendTempGtMax_True:
