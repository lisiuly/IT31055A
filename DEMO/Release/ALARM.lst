  1308 0000F27D                     .CODE
  1309                              ;-------------------------------------------------------
  1310                              ; 函数: F_JudgeRFC
  1311                              ; 作用: 温湿度采样的统一入口，只在允许采样的时间点触发一次刷新。
  1312                              ; 输入: R_KeyFlag、RTC+2、R_TimeStatus.HalfSecToggle。
  1313                              ; 输出: 满足条件时跳到 F_UpdateTHFromGXHTV4 刷新温湿度；否则直接返回。
  1314                              ; 说明: 这里用“整分 00 秒 + 半秒翻转边沿”双重门控，避免同一分钟内重复采样。
  1315                              .PUBLIC     F_JudgeRFC
  1316 0000F27D                     F_JudgeRFC:					; 温度湿度RFC检测模块
  1317                                  %btst	R_KeyFlag,D_KeyRelDis,ExitJudge
  1318 0000F27D AD 8F 00          1           lda     R_KeyFlag               ;ex.   
  1319 0000F280 29 10             1           and     #D_KeyRelDis              ;  %btst 10H,_BIT0,N
  1320 0000F282 D0 4E             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1321                              
  1322                                  ; 规格改为 60 秒采样，只在整分 00 秒触发一次。
  1323 0000F284 AD 85 00                LDA     RTC+2
  1324 0000F287 C9 00                   CMP     #00H
  1325 0000F289 D0 47                   BNE     ExitJudge
  1326                              
  1327 0000F28B                     CheckHalfSecToggle:
  1328                                  ; 同步读取 GXHTV4，只在一个半秒边沿触发一次，避免 00/30 秒重复采样
  1329                                  %btst   R_TimeStatus, HalfSecToggle, ExitJudge
  1330 0000F28B AD 89 00          1           lda     R_TimeStatus               ;ex.   
  1331 0000F28E 29 40             1           and     #HalfSecToggle              ;  %btst 10H,_BIT0,N
  1332 0000F290 D0 40             1           bne     ExitJudge               ;  if(10H.0=1) goto N 
  1333 0000F292 4C 95 F2                JMP     F_UpdateTHFromGXHTV4
  1334                              
  1335                              ;-------------------------------------------------------
  1336                              ; 函数: F_UpdateTHFromGXHTV4
  1337                              ; 作用: 从 GXHTV4 读取原始温湿度值，并回填到 Alarm 兼容变量。
  1338                              ; 输入: 外设读数 TEMP_INTEGAH/TEMP_INTEGAL/HUM。
  1339                              ; 输出: R_TempCH、R_TempCL、R_HUM 被更新，然后转入 CalculateRFC。
  1340                              ; 说明: 该函数只负责“采样搬运”，不做显示格式转换和极值更新。
  1341                              .PUBLIC		F_UpdateTHFromGXHTV4
  1342 0000F295                     F_UpdateTHFromGXHTV4:
  1343 0000F295 20 BA ED                JSR		F_ReadGXHTV4Data
  1344 0000F298 AD AB 00                LDA		TEMP_INTEGAH
  1345 0000F29B 8D 86 01                STA		R_TempCH
  1346 0000F29E AD AC 00                LDA		TEMP_INTEGAL
  1347 0000F2A1 8D 87 01                STA		R_TempCL
  1348 0000F2A4 AD AD 00                LDA		HUM
  1349 0000F2A7 8D 88 01                STA		R_HUM
  1350 0000F2AA 4C AD F2                JMP		CalculateRFC
  1351                              
  1352                              ;-------------------------------------------------------
  1353                              ; 函数: CalculateRFC
  1354                              ; 作用: 根据原始温度高字节的符号位设置当前温度正负标志，并进入温湿度换算主链。
  1355                              ; 输入: R_TempCH 的 bit7 符号位。
  1356                              ; 输出: R_SpecFlag.D_Neg 被更新，随后跳到 F_GetTHVlaue。
  1357                              ; 说明: 这里只做符号判定，不直接修改温度数值本身。
  1358                              .PUBLIC		CalculateRFC
  1359 0000F2AD                     CalculateRFC:
  1360                                  ; 温度符号检查
  1361 0000F2AD AD 86 01                LDA     R_TempCH
  1362 0000F2B0 29 80                   AND     #80H
  1363 0000F2B2 F0 13                   BEQ     TemperatureIsPositive
  1364                              
  1365                                  ; 温度为负值
  1366                                  %bits   R_SpecFlag, D_Neg
  1367 0000F2B4 AD C1 01          1           lda     R_SpecFlag               ;ex.  
  1368 0000F2B7 09 10             1           ora     #D_Neg              ;  %bits 10H,_BIT0
  1369                            1 		                   ;  10H.0=1
  1370 0000F2B9 8D C1 01          1           sta     R_SpecFlag               ;
  1371                              
  1372 0000F2BC                     LoadTemperatureValue:
  1373                                  %bits   R_TimeStatus, AddOthers
  1374 0000F2BC AD 89 00          1           lda     R_TimeStatus               ;ex.  
  1375 0000F2BF 09 10             1           ora     #AddOthers              ;  %bits 10H,_BIT0
  1376                            1 		                   ;  10H.0=1
  1377 0000F2C1 8D 89 00          1           sta     R_TimeStatus               ;
  1378 0000F2C4 4C 92 F3                JMP     F_GetTHVlaue
  1379                              
  1380 0000F2C7                     TemperatureIsPositive:
  1381                                  %bitr   R_SpecFlag, D_Neg
  1382 0000F2C7 AD C1 01          1           lda     R_SpecFlag               ;ex.  
  1383 0000F2CA 29 EF             1           and     #.NOT.D_Neg         ;  %bitr 10H,_BIT0;  10H.0=0
  1384 0000F2CC 8D C1 01          1           sta     R_SpecFlag
  1385 0000F2CF 4C BC F2                JMP     LoadTemperatureValue
  1386                              
  1387 0000F2D2                     ExitJudge:
  1388 0000F2D2 60                      RTS
  1389                              
  1390                              ;-------------------------------------------------------
  1391                              ; 函数: F_CheckLowBattery
  1392                              ; 作用: 读取 LVD 状态并做去抖，稳定后更新低电池标志。
  1393                              ; 输入: P_LVD_Ctrl.D_LVD_State、R_BatteryFlags、R_BatteryDetCnt。
  1394                              ; 输出: R_BatteryFlags.D_BatteryLow 可能被置位/清位，R_BatteryDetCnt 计数更新。
  1395                              ; 说明: 只有连续多次采样结果一致后才真正改标志，避免电压边缘抖动导致误报。
  1396 0000F2D3                     F_CheckLowBattery:
  1397 0000F2D3 A5 1B                   LDA		P_LVD_Ctrl
  1398 0000F2D5 29 01                   AND		#D_LVD_State
  1399 0000F2D7 D0 27                   BNE		BatterySampleLow
  1400                              
  1401 0000F2D9                     BatterySampleHigh:
  1402 0000F2D9 AD 84 01                LDA		R_BatteryFlags
  1403 0000F2DC 29 01                   AND		#D_BatteryLow
  1404 0000F2DE F0 47                   BEQ		BatteryClearCounter
  1405 0000F2E0 EE 85 01                INC		R_BatteryDetCnt
  1406 0000F2E3 AD 85 01                LDA		R_BatteryDetCnt
  1407 0000F2E6 C9 05                   CMP		#C_BatteryDetDebounce
  1408 0000F2E8 90 42                   BCC		BatteryExit
  1409 0000F2EA AD 84 01                LDA		R_BatteryFlags
  1410 0000F2ED 29 FE                   AND		#.not.D_BatteryLow
  1411 0000F2EF 8D 84 01                STA		R_BatteryFlags
  1412                                  %bits   R_TimeStatus, AddOthers
  1413 0000F2F2 AD 89 00          1           lda     R_TimeStatus               ;ex.  
  1414 0000F2F5 09 10             1           ora     #AddOthers              ;  %bits 10H,_BIT0
  1415                            1 		                   ;  10H.0=1
  1416 0000F2F7 8D 89 00          1           sta     R_TimeStatus               ;
  1417 0000F2FA A9 00                   LDA		#00H
  1418 0000F2FC 8D 85 01                STA		R_BatteryDetCnt
  1419 0000F2FF 60                      RTS
  1420                              
  1421 0000F300                     BatterySampleLow:
  1422 0000F300 AD 84 01                LDA		R_BatteryFlags
  1423 0000F303 29 01                   AND		#D_BatteryLow
  1424 0000F305 D0 1A                   BNE		BatteryLowKeep
  1425 0000F307 EE 85 01                INC		R_BatteryDetCnt
  1426 0000F30A AD 85 01                LDA		R_BatteryDetCnt
  1427 0000F30D C9 05                   CMP		#C_BatteryDetDebounce
  1428 0000F30F 90 1B                   BCC		BatteryExit
  1429 0000F311 AD 84 01                LDA		R_BatteryFlags
  1430 0000F314 09 01                   ORA		#D_BatteryLow
  1431 0000F316 8D 84 01                STA		R_BatteryFlags
  1432                                  %bits   R_TimeStatus, AddOthers
  1433 0000F319 AD 89 00          1           lda     R_TimeStatus               ;ex.  
  1434 0000F31C 09 10             1           ora     #AddOthers              ;  %bits 10H,_BIT0
  1435                            1 		                   ;  10H.0=1
  1436 0000F31E 8D 89 00          1           sta     R_TimeStatus               ;
  1437                              
  1438 0000F321                     BatteryLowKeep:
  1439 0000F321 A9 00                   LDA		#00H
  1440 0000F323 8D 85 01                STA		R_BatteryDetCnt
  1441 0000F326 60                      RTS
  1442                              
  1443 0000F327                     BatteryClearCounter:
  1444 0000F327 A9 00                   LDA		#00H
  1445 0000F329 8D 85 01                STA		R_BatteryDetCnt
  1446                              
  1447 0000F32C                     BatteryExit:
  1448 0000F32C 60                      RTS
  1449                              
  1450                              ;-------------------------------------------------------
  1451                              ; 函数: F_MoldAlarm128Hz
  1452                              ; 作用: 以 128Hz 节拍驱动霉菌报警的开关节奏。
  1453                              ; 输入: R_MoldSetValue、R_DispHum、R_MoldAlarmTm、R_MoldAlarmIdx。
  1454                              ; 输出: R_SoundOn、R_MoldAlarmTm、R_MoldAlarmIdx。
  1455                              ; 说明: 当湿度达到阈值后，按 T_MoldAlarmPattern 预定义的节奏循环鸣叫。
  1456 0000F32D                     F_MoldAlarm128Hz:
  1457 0000F32D AD A1 00                LDA		R_MoldSetValue
  1458 0000F330 D0 02                   BNE		MoldAlarm_CheckHum
  1459 0000F332 A9 65                   LDA		#C_MoldDefaultThreshold
  1460                              
  1461 0000F334                     MoldAlarm_CheckHum:
  1462 0000F334 CD D2 01                CMP		R_DispHum
  1463 0000F337 90 16                   BCC		MoldAlarm_Active
  1464 0000F339 F0 14                   BEQ		MoldAlarm_Active
  1465                              
  1466 0000F33B                     MoldAlarm_Stop:
  1467 0000F33B A9 00                   LDA		#00H
  1468 0000F33D 8D 80 01                STA		R_SoundOn
  1469 0000F340 8D 82 01                STA		R_MoldAlarmTm
  1470 0000F343 8D 83 01                STA		R_MoldAlarmIdx
  1471                              	%bitr	R_KeyFlag,D_Alarming
  1472 0000F346 AD 8F 00          1           lda     R_KeyFlag               ;ex.  
  1473 0000F349 29 BF             1           and     #.NOT.D_Alarming         ;  %bitr 10H,_BIT0;  10H.0=0
  1474 0000F34B 8D 8F 00          1           sta     R_KeyFlag
  1475 0000F34E 60                      RTS
  1476                              
  1477 0000F34F                     MoldAlarm_Active:
  1478                              	%bits	R_KeyFlag,D_Alarming
  1479 0000F34F AD 8F 00          1           lda     R_KeyFlag               ;ex.  
  1480 0000F352 09 40             1           ora     #D_Alarming              ;  %bits 10H,_BIT0
  1481                            1 		                   ;  10H.0=1
  1482 0000F354 8D 8F 00          1           sta     R_KeyFlag               ;
  1483 0000F357 AD 82 01                LDA		R_MoldAlarmTm
  1484 0000F35A F0 04                   BEQ		MoldAlarm_LoadStep
  1485 0000F35C CE 82 01                DEC		R_MoldAlarmTm
  1486 0000F35F 60                      RTS
  1487                              
  1488 0000F360                     MoldAlarm_LoadStep:
  1489 0000F360 AE 83 01                LDX		R_MoldAlarmIdx
  1490 0000F363 BD 81 F3                LDA		T_MoldAlarmPattern,X
  1491 0000F366 C9 FF                   CMP		#0FFH
  1492 0000F368 D0 08                   BNE		MoldAlarm_StoreStep
  1493 0000F36A A2 00                   LDX		#00H
  1494 0000F36C 8E 83 01                STX		R_MoldAlarmIdx
  1495 0000F36F AD 81 F3                LDA		T_MoldAlarmPattern
  1496                              
  1497 0000F372                     MoldAlarm_StoreStep:
  1498 0000F372 8D 82 01                STA		R_MoldAlarmTm
  1499 0000F375 BD 82 F3                LDA		T_MoldAlarmPattern+1,X
  1500 0000F378 8D 80 01                STA		R_SoundOn
  1501 0000F37B E8                      INX
  1502 0000F37C E8                      INX
  1503 0000F37D 8E 83 01                STX		R_MoldAlarmIdx
  1504 0000F380 60                      RTS
  1505                              
  1506 0000F381                     T_MoldAlarmPattern:
  1507 0000F381 08 01 08 00             DB		08,01,08,00
                           
  1508 0000F385 08 01 08 00             DB		08,01,08,00
                           
  1509 0000F389 08 01 08 00             DB		08,01,08,00
                           
  1510 0000F38D 08 01 48 00             DB		08,01,72,00
                           
  1511 0000F391 FF                      DB		0FFH
  1512                              
  1513                              ;-------------------------------------------------------
  1514                              ; 输入：R_TempCH, R_TempCL - 温度值(高字节和低字节)
  1515                              ;       R_HUM - 湿度值
  1516                              ; 输出：R_DispTemper - 摄氏度温度显示值(BCD格式)
  1517                              ;       R_DispTemper_F - 华氏度温度显示值(BCD格式)
  1518                              ;       R_DispHum - 湿度显示值(BCD格式)
  1519                              ; 说明：这是 Alarm 模块的主处理链，依次完成温度换算、湿度换算、HH/LL 判定、极值更新、趋势更新和历史记录更新。
  1520                              .PUBLIC     F_GetTHVlaue
  1521 0000F392                     F_GetTHVlaue:				; 获取温湿度值并转换为显示格式
  1522 0000F392 20 A5 F3                JSR     ProcessTemperature
  1523 0000F395 20 E0 F3                JSR     ProcessHumidity
  1524 0000F398 20 FC F3                JSR     F_Judge_HHLL
  1525 0000F39B 20 75 F4                JSR     UpdateExtremeValues
  1526 0000F39E 20 98 F5                JSR		F_UpdateTrendState
  1527 0000F3A1 4C 8A F7                JMP		F_HistoryOnSample
  1528                              
  1529                              ;-------------------------------------------------------
  1530                              ; 函数: F_RefreshTrendFlags
  1531                              ; 作用: 兼容保留的空实现。
  1532                              ; 说明: 旧版“累计步进”趋势算法曾在这里统一刷新箭头；新窗口算法已直接在 F_UpdateTempTrendState / F_UpdateHumTrendState 内决定方向，
  1533                              ;       因此该入口保留为 RTS，避免旧调用点或阅读路径产生歧义。
  1534 0000F3A4                     F_RefreshTrendFlags:
  1535 0000F3A4 60                      RTS
  1536                              
  1537                              ;-------------------------------------------------------
  1538                              ; 函数: ProcessTemperature
  1539                              ; 作用: 把当前温度原始值转成摄氏 BCD，并继续生成华氏显示值。
  1540                              ; 输入: R_TempCH、R_TempCL。
  1541                              ; 输出: R_DispTemper、R_DispTemper_F。
  1542                              ; 说明: 温度符号位在 CalculateRFC 中处理，这里先按绝对值转摄氏，再调用华氏换算。
  1543 0000F3A5                     ProcessTemperature:
  1544                                  ; 处理摄氏度温度
  1545 0000F3A5 AD 86 01                LDA     R_TempCH
  1546 0000F3A8 29 7F                   AND     #7FH                ; 清除符号位
  1547 0000F3AA AA                      TAX
  1548 0000F3AB AD 87 01                LDA     R_TempCL
  1549                                  
  1550 0000F3AE                     ConvertTemperatureToBCD:
  1551 0000F3AE 20 AB EF                JSR     F_CAL_HEX_BCD2      ; 转换为BCD格式
  1552                                  
  1553                                  ; ; 保存温度显示值(BCD格式)
  1554                                  ; LDA     OUT_M
  1555                                  ; STA     R_DispTemper        ; 百位和十位
  1556                                  ; ASL     R_DispTemper        ; 将十位左移4位，为个位腾出位置
  1557                                  ; ASL     R_DispTemper
  1558                                  ; ASL     R_DispTemper
  1559                                  ; ASL     R_DispTemper
  1560                                  
  1561                                  ; LDA     OUT_L
  1562                                  ; LSR     A                   ; 将个位右移4位
  1563                                  ; LSR     A
  1564                                  ; LSR     A
  1565                                  ; LSR     A
  1566                                  ; ORA     R_DispTemper        ; 合并十位和个位
  1567                                  ; STA     R_DispTemper        ; 保存完整的温度值(十位个位)
  1568 0000F3B1 AD BB 00                LDA     OUT_M
  1569 0000F3B4 8D CC 01                STA     R_DispTemper+0    ; 百位和十位
  1570 0000F3B7 AD BA 00                LDA     OUT_L
  1571 0000F3BA 8D CD 01                STA     R_DispTemper+1    ; 个位和小数位	   
  1572                                  ; 转换并保存华氏度温度
  1573 0000F3BD 4C C0 F3                JMP     ConvertToFahrenheit
  1574                               ;   RTS    
  1575                              ;-------------------------------------------------------
  1576                              ; 函数: ConvertToFahrenheit
  1577                              ; 作用: 将当前摄氏原始值转换成华氏值，并保存为 BCD 显示格式。
  1578                              ; 输入：R_TempCH, R_TempCL - 摄氏度温度值
  1579                              ; 输出：R_DispTemper_F - 华氏度温度显示值(BCD格式)
  1580 0000F3C0                     ConvertToFahrenheit:
  1581 0000F3C0 AD 86 01                LDA     R_TempCH
  1582 0000F3C3 AA                      TAX
  1583 0000F3C4 AD 87 01                LDA     R_TempCL
  1584 0000F3C7 20 02 F0                JSR     F_CHANGE_CF         ; 调用摄氏度转华氏度函数
  1585                                  
  1586                                  ; 转换华氏度值为BCD格式
  1587 0000F3CA AE B6 00                LDX     X_M
  1588 0000F3CD AD B7 00                LDA     X_L
  1589 0000F3D0 20 AB EF                JSR     F_CAL_HEX_BCD2
  1590                                  
  1591                                  ; 保存华氏度显示值
  1592 0000F3D3 AD BB 00                LDA     OUT_M
  1593 0000F3D6 8D C6 01                STA     R_DispTemper_F+0    ; 百位和十位
  1594 0000F3D9 AD BA 00                LDA     OUT_L
  1595 0000F3DC 8D C7 01                STA     R_DispTemper_F+1    ; 个位和小数位	
  1596 0000F3DF 60                      RTS
  1597                                  
  1598                              ;-------------------------------------------------------
  1599                              ; 函数: ProcessHumidity
  1600                              ; 作用: 把原始湿度值转换成 BCD 显示格式。
  1601                              ; 输入：R_HUM - 湿度值
  1602                              ; 输出：R_DispHum - 湿度显示值(BCD格式)
  1603 0000F3E0                     ProcessHumidity:
  1604 0000F3E0 AD 88 01                LDA     R_HUM               ; 读取湿度值
  1605 0000F3E3 C9 64               	CMP		#C_HumRaw100
  1606 0000F3E5 90 06               	BCC		ProcessHumidity_ConvertBCD
  1607 0000F3E7 A9 99               	LDA		#C_HumDisp99
  1608 0000F3E9 8D D2 01            	STA		R_DispHum           ; 两位湿度显示链路对 100%RH 做 99 封顶
  1609 0000F3EC 60                  	RTS
  1610                              
  1611 0000F3ED                     ProcessHumidity_ConvertBCD:
  1612 0000F3ED A2 00               	LDX		#00
  1613 0000F3EF AD 88 01                LDA     R_HUM               ; 读取湿度值
  1614 0000F3F2 20 AB EF                JSR     F_CAL_HEX_BCD2      ; 转换为BCD格式
  1615                                  
  1616                                  ; 保存湿度显示值
  1617 0000F3F5 AD BA 00                LDA     OUT_L
  1618 0000F3F8 8D D2 01                STA     R_DispHum           ; 保存湿度显示值(0-99%)
  1619 0000F3FB 60                      RTS
  1620                                  
  1621                              ;-------------------------------------------------------
  1622                              ;;判断温湿度有无超过上下限
  1623                              ; 输入：R_HUM R_DispTemper
  1624                              ; 输出：SpecFlag,(D_TempLL+D_TempHH+D_HumLL+D_HumHH)
  1625                              ; 说明：先清掉旧的 HH/LL 标志，再分别调用温度和湿度判断逻辑重算当前报警状态。
  1626 0000F3FC                     F_Judge_HHLL:		;判断温湿度有无超过上下限
  1627                                   %bitr    R_SpecFlag,(D_TempLL+D_TempHH+D_HumLL+D_HumHH)	
  1628 0000F3FC AD C1 01          1           lda     R_SpecFlag               ;ex.  
  1629 0000F3FF 29 1D             1           and     #.NOT.(D_TempLL+D_TempHH+D_HumLL+D_HumHH)         ;  %bitr 10H,_BIT0;  10H.0=0
  1630 0000F401 8D C1 01          1           sta     R_SpecFlag
  1631 0000F404 20 0A F4            	JSR		F_Judge_TempHHLL	
  1632 0000F407 4C 38 F4            	JMP		F_Judge_HumHHLL	
  1633                              ;	RTS
  1634                              	
  1635 0000F40A                     F_Judge_TempHHLL:	
  1636                                  %btst    R_SpecFlag,D_Neg,?L_JudgeLL   
  1637 0000F40A AD C1 01          1           lda     R_SpecFlag               ;ex.   
  1638 0000F40D 29 10             1           and     #D_Neg              ;  %btst 10H,_BIT0,N
  1639 0000F40F D0 17             1           bne     ?L_JudgeLL               ;  if(10H.0=1) goto N 
  1640 0000F411 AD CC 01                LDA		R_DispTemper+0		;判断有无超过上下限
  1641 0000F414 C9 05                       CMP		#0x05
  1642 0000F416 90 0F                       BCC		?L_Exit
  1643 0000F418 D0 05                       BNE		?L_SetHH
  1644 0000F41A AD CD 01                    LDA		R_DispTemper+1
  1645 0000F41D F0 08                       BEQ		?L_Exit
  1646 0000F41F                          ?L_SetHH:
  1647                                       %bits    R_SpecFlag,D_TempHH	
  1648 0000F41F AD C1 01          1           lda     R_SpecFlag               ;ex.  
  1649 0000F422 09 40             1           ora     #D_TempHH              ;  %bits 10H,_BIT0
  1650                            1 		                   ;  10H.0=1
  1651 0000F424 8D C1 01          1           sta     R_SpecFlag               ;
  1652 0000F427                        ?L_Exit: 
  1653 0000F427 60                     	RTS   
  1654 0000F428                         ?L_JudgeLL:
  1655 0000F428 AD CC 01                LDA		R_DispTemper+0	
  1656 0000F42B C9 01                   CMP		#0x01
  1657 0000F42D 90 F8                   BCC		?L_Exit
  1658                                   %bits    R_SpecFlag,D_TempLL
  1659 0000F42F AD C1 01          1           lda     R_SpecFlag               ;ex.  
  1660 0000F432 09 20             1           ora     #D_TempLL              ;  %bits 10H,_BIT0
  1661                            1 		                   ;  10H.0=1
  1662 0000F434 8D C1 01          1           sta     R_SpecFlag               ;
  1663 0000F437 60                     	RTS 
  1664                                  
  1665 0000F438                     F_Judge_HumHHLL: 	
  1666 0000F438 AD 88 01            	LDA		R_HUM
  1667 0000F43B C9 64               	CMP		#C_HumRaw100
  1668 0000F43D 90 09               	BCC		JudgeHumHHLL_CheckDisp
  1669                              	%bits    R_SpecFlag,D_HumHH 
  1670 0000F43F AD C1 01          1           lda     R_SpecFlag               ;ex.  
  1671 0000F442 09 80             1           ora     #D_HumHH              ;  %bits 10H,_BIT0
  1672                            1 		                   ;  10H.0=1
  1673 0000F444 8D C1 01          1           sta     R_SpecFlag               ;
  1674 0000F447 60                  	RTS
  1675                              
  1676 0000F448                     JudgeHumHHLL_CheckDisp:
  1677 0000F448 AD D2 01                LDA		R_DispHum		;判断有无超过上下限
  1678 0000F44B C9 99                   CMP		#0x99
  1679 0000F44D F0 0B                   BEQ		?L_Next
  1680 0000F44F 90 09                   BCC		?L_Next 
  1681                                  %bits    R_SpecFlag,D_HumHH 
  1682 0000F451 AD C1 01          1           lda     R_SpecFlag               ;ex.  
  1683 0000F454 09 80             1           ora     #D_HumHH              ;  %bits 10H,_BIT0
  1684                            1 		                   ;  10H.0=1
  1685 0000F456 8D C1 01          1           sta     R_SpecFlag               ;
  1686 0000F459 60                      RTS
  1687 0000F45A                        ?L_Next:
  1688 0000F45A AD D2 01                LDA		R_DispHum  
  1689 0000F45D C9 01               	CMP		#0x01
  1690 0000F45F B0 08                   BCS		?L_Exit
  1691                                  %bits    R_SpecFlag,D_HumLL
  1692 0000F461 AD C1 01          1           lda     R_SpecFlag               ;ex.  
  1693 0000F464 09 02             1           ora     #D_HumLL              ;  %bits 10H,_BIT0
  1694                            1 		                   ;  10H.0=1
  1695 0000F466 8D C1 01          1           sta     R_SpecFlag               ;
  1696 0000F469                         ?L_Exit:
  1697 0000F469 60                      RTS
  1698                              
  1699                              ;-------------------------------------------------------
  1700                              ; 函数: F_IsCurrentTempInRange
  1701                              ; 作用: 根据当前 HH/LL 标志判断温度是否仍处于可记录的显示范围内。
  1702                              ; 输出: C=1 表示当前温度在 -9.9~50.0 的记录范围内；C=0 表示已进入 HH/LL。
  1703 0000F46A                     F_IsCurrentTempInRange:
  1704 0000F46A AD C1 01            	LDA		R_SpecFlag
  1705 0000F46D 29 60               	AND		#(D_TempHH+D_TempLL)
  1706 0000F46F F0 02               	BEQ		CurrentTempInRange
  1707 0000F471 18                  	CLC
  1708 0000F472 60                  	RTS
  1709                              
  1710 0000F473                     CurrentTempInRange:
  1711 0000F473 38                  	SEC
  1712 0000F474 60                  	RTS
  1713                                      
  1714                              ; 更新温湿度极值记录(BCD格式)
  1715                              ; 输入：R_DispTemper - 当前温度值(BCD格式)
  1716                              ;       R_DispHum - 当前湿度值(BCD格式)
  1717                              ;       R_TempMax, R_TempMin - 温度最高/最低记录(BCD格式)
  1718                              ;       R_HumMax, R_HumMin - 湿度最高/最低记录(BCD格式)
  1719                              ; 说明：先更新温度极值，再更新湿度极值；两部分共享当前采样值，但比较规则不同。
  1720 0000F475                     UpdateExtremeValues:
  1721                                  ; 更新温度极值
  1722 0000F475 20 6A F4                JSR		F_IsCurrentTempInRange
  1723 0000F478 90 03                   BCC		UpdateExtremeValues_SkipTemp
  1724 0000F47A 20 80 F4                JSR     UpdateTemperatureExtremes
  1725                                  
  1726                                  ; 更新湿度极值
  1727 0000F47D                     UpdateExtremeValues_SkipTemp:
  1728 0000F47D 4C 6E F5                JMP     UpdateHumidityExtremes
  1729                               ;   RTS
  1730                                  
  1731                              ;-------------------------------------------------------
  1732                              ; 更新温度极值记录(BCD格式，符号位与数值分离)
  1733                              ; 输入：R_DispTemper - 当前温度值(BCD格式，正数)
  1734                              ;       R_SpecFlag.D_Neg - 当前温度符号(1=负，0=正)
  1735                              ;       R_TempMax, R_TempMin - 温度最高/最低记录(BCD格式)
  1736                              ;       R_TempMax_Sign, R_TempMin_Sign - 温度符号记录(1=负，0=正)
  1737                              ; 输出：更新R_TempMax, R_TempMin, R_TempMax_Sign, R_TempMin_Sign
  1738                              ; 说明：温度极值比较需要把“符号”和“绝对值”分开处理，因此正温、负温、跨零三类路径都是分支展开的。
  1739 0000F480                     UpdateTemperatureExtremes:
  1740                                  ; 比较当前温度与最高温度记录
  1741 0000F480 AD C1 01                LDA     R_SpecFlag
  1742 0000F483 29 10                   AND     #D_Neg              ; 当前温度符号
  1743 0000F485 D0 4D                   BNE     CurrentTempIsNeg_1    ; 当前温度为负
  1744                                  
  1745                                  ; 当前温度为正
  1746 0000F487 AD C3 01                LDA     R_TempMax_Sign
  1747 0000F48A 29 10                   AND     #D_Neg              ; 当前温度符号    
  1748 0000F48C D0 1A                   BNE     UpdateTempMax       ; 最高温度为负，当前为正，直接更新
  1749                              
  1750                                  ; 两者均为正，比较数值
  1751 0000F48E AD CC 01                LDA     R_DispTemper+0    ; 当前温度百位和十位
  1752 0000F491 CD CE 01                CMP     R_TempMax+0    ; 最高温度百位和十位
  1753 0000F494 F0 05                   BEQ     CompareTempMaxLow   ; 百位和十位相等，比较个位和小数位
  1754 0000F496 B0 10                   BCS     UpdateTempMax       ; 当前温度>最高记录，更新最高温度
  1755 0000F498 4C D7 F4                JMP     CheckTempMin        ; 当前温度<最高记录，检查最低记录
  1756                              
  1757 0000F49B                     CompareTempMaxLow:
  1758 0000F49B AD CD 01                LDA     R_DispTemper+1    ; 当前温度个位和小数位
  1759 0000F49E CD CF 01                CMP     R_TempMax+1    ; 最高温度个位和小数位
  1760 0000F4A1 90 34                   BCC     CheckTempMin        ; 当前温度<最高记录，检查最低记录
  1761 0000F4A3 F0 32                   BEQ     CheckTempMin        ; 当前温度=最高记录，检查最低记录
  1762 0000F4A5 4C A8 F4                JMP     UpdateTempMax       ; 当前温度>最高记录，更新最高温度
  1763                                  
  1764 0000F4A8                     UpdateTempMax:
  1765                                  ; 更新最高温度记录
  1766 0000F4A8 AD CC 01                LDA     R_DispTemper+0    
  1767 0000F4AB 8D CE 01                STA     R_TempMax+0    ; 百位和十位
  1768 0000F4AE AD CD 01                LDA     R_DispTemper+1
  1769 0000F4B1 8D CF 01                STA     R_TempMax+1    ; 个位和小数位
  1770                                  
  1771 0000F4B4 AD C1 01                LDA     R_SpecFlag
  1772                              ;    AND     #D_Neg
  1773 0000F4B7 8D C3 01                STA     R_TempMax_Sign      ; 更新符号位    	
  1774 0000F4BA AD C6 01                LDA     R_DispTemper_F+0    ; 百位和十位
  1775 0000F4BD 8D C8 01                STA		R_MAXDispTemper_F+0 
  1776 0000F4C0 AD C7 01                LDA     R_DispTemper_F+1    ; 个位和小数位    
  1777 0000F4C3 8D C9 01                STA		R_MAXDispTemper_F+1    	
  1778 0000F4C6 AD A9 00                LDA		R_TempFlag
  1779 0000F4C9 29 04                   AND		#D_TempFReg
  1780 0000F4CB 0D C3 01                ORA		R_TempMax_Sign
  1781 0000F4CE 8D C3 01                STA		R_TempMax_Sign
  1782 0000F4D1 4C D7 F4                JMP     CheckTempMin
  1783 0000F4D4                     CurrentTempIsNeg_1:    
  1784 0000F4D4 4C 2A F5            	JMP   	CurrentTempIsNeg    
  1785 0000F4D7                     CheckTempMin:
  1786                                  ; 检查当前温度符号
  1787 0000F4D7 AD C1 01                LDA     R_SpecFlag
  1788 0000F4DA 29 10                   AND     #D_Neg
  1789 0000F4DC D0 6E                   BNE     CurrentTempNegMin   ; 当前温度为负
  1790                                  
  1791                                  ; 当前温度为正
  1792 0000F4DE AD C2 01                LDA     R_TempMin_Sign
  1793 0000F4E1 29 10                   AND     #D_Neg              ; 当前温度符号
  1794 0000F4E3 D0 44                   BNE     ExitTempUpdate       ; 最低温度为负，当前为正，不更新
  1795                                  
  1796                                  ; 两者均为正，比较数值
  1797 0000F4E5 AD CC 01                LDA     R_DispTemper+0    ; 当前温度百位和十位
  1798 0000F4E8 CD D0 01                CMP     R_TempMin+0
  1799 0000F4EB F0 05                   BEQ     CompareTempMinLow   ; 百位和十位相等，比较个位和小数位
  1800 0000F4ED 90 0E                   BCC     UpdateTempMin       ; 当前温度<最低记录，更新最低温度
  1801 0000F4EF 4C 29 F5                JMP     ExitTempUpdate      ; 当前温度>最低记录，不更新
  1802 0000F4F2                     CompareTempMinLow:
  1803 0000F4F2 AD CD 01                LDA     R_DispTemper+1    ; 当前温度个位和小数位
  1804 0000F4F5 CD D1 01                CMP     R_TempMin+1
  1805 0000F4F8 B0 2F                   BCS     ExitTempUpdate      ; 当前温度>最低记录，不更新
  1806 0000F4FA 4C FD F4                JMP     UpdateTempMin       ; 当前温度<最低记录，更新最低温度
  1807                                  
  1808 0000F4FD                     UpdateTempMin:
  1809                                  ; 更新最低温度记录
  1810 0000F4FD AD CC 01                LDA     R_DispTemper+0
  1811 0000F500 8D D0 01                STA     R_TempMin+0
  1812 0000F503 AD CD 01                LDA     R_DispTemper+1
  1813 0000F506 8D D1 01                STA     R_TempMin+1
  1814 0000F509 AD C1 01                LDA     R_SpecFlag
  1815                              ;    AND     #D_Neg
  1816 0000F50C 8D C2 01                STA     R_TempMin_Sign      ; 更新符号位
  1817 0000F50F AD C6 01                LDA     R_DispTemper_F+0    ; 百位和十位
  1818 0000F512 8D CA 01                STA		R_MINDispTemper_F+0 
  1819 0000F515 AD C7 01                LDA     R_DispTemper_F+1    ; 个位和小数位    
  1820 0000F518 8D CB 01                STA		R_MINDispTemper_F+1    	
  1821 0000F51B AD A9 00                LDA		R_TempFlag
  1822 0000F51E 29 04                   AND		#D_TempFReg
  1823 0000F520 0D C2 01                ORA		R_TempMin_Sign
  1824 0000F523 8D C2 01                STA		R_TempMin_Sign
  1825 0000F526 4C 29 F5                JMP     ExitTempUpdate
  1826                                  
  1827 0000F529                     ExitTempUpdate:
  1828 0000F529 60                      RTS    
  1829                              	
  1830 0000F52A                     CurrentTempIsNeg:
  1831                                  ; 当前温度为负
  1832 0000F52A AD C3 01                LDA     R_TempMax_Sign
  1833 0000F52D 29 10                   AND     #D_Neg              ; 当前温度符号    
  1834 0000F52F D0 03                   BNE     CompareNegativeMax  ; 最高温度也为负，比较数值
  1835                                  
  1836                                  ; 最高温度为正，当前为负，不更新
  1837 0000F531 4C D7 F4                JMP     CheckTempMin
  1838                                  
  1839 0000F534                     CompareNegativeMax:
  1840                                  ; 两者均为负，比较数值
  1841 0000F534 AD CC 01                LDA     R_DispTemper+0
  1842 0000F537 CD CE 01                CMP     R_TempMax+0
  1843 0000F53A F0 05                   BEQ     CompareNegativeMaxLow   ; 百位和十位相等，比较个位和小数位
  1844 0000F53C B0 99                   BCS     CheckTempMin        ; 当前温度>=最高记录（负数比较：绝对值越小，值越大）
  1845 0000F53E 4C A8 F4                JMP     UpdateTempMax       ; 当前温度<最高记录，更新最高温度
  1846                              
  1847 0000F541                     CompareNegativeMaxLow:
  1848 0000F541 AD CD 01                LDA     R_DispTemper+1    ; 当前温度个位和小数位
  1849 0000F544 CD CF 01                CMP     R_TempMax+1
  1850 0000F547 B0 8E                   BCS     CheckTempMin      ; 当前温度>=最高记录，不更新
  1851 0000F549 4C A8 F4                JMP     UpdateTempMax     ; 当前温度<最高记录，更新最高温度
  1852                                  
  1853                                  
  1854 0000F54C                     CurrentTempNegMin:
  1855                                  ; 当前温度为负
  1856 0000F54C AD C2 01                LDA     R_TempMin_Sign
  1857 0000F54F 29 10                   AND     #D_Neg              ; 当前温度符号    
  1858 0000F551 D0 03                   BNE     CompareNegativeMin  ; 最低温度也为负，比较数值
  1859                                  
  1860                                  ; 最低温度为正，当前为负，更新
  1861 0000F553 4C FD F4                JMP     UpdateTempMin
  1862                                  
  1863 0000F556                     CompareNegativeMin:
  1864                                  ; 两者均为负，比较数值
  1865 0000F556 AD CC 01                LDA     R_DispTemper+0
  1866 0000F559 CD D0 01                CMP     R_TempMin+0
  1867 0000F55C F0 05                   BEQ     CompareNegativeMinLow   ; 百位和十位相等，比较个位和小数位
  1868 0000F55E B0 9D                   BCS     UpdateTempMin       ; 当前温度<最低记录（负数比较：绝对值越大，值越小）
  1869                                  ; 当前温度>=最低记录，不更新
  1870 0000F560 4C 29 F5                JMP     ExitTempUpdate    
  1871 0000F563                     CompareNegativeMinLow:
  1872 0000F563 AD CD 01                LDA     R_DispTemper+1    ; 当前温度个位和小数位
  1873 0000F566 CD D1 01                CMP     R_TempMin+1
  1874 0000F569 B0 BE                   BCS     ExitTempUpdate      ; 当前温度>=最低记录，不更新
  1875 0000F56B 4C FD F4                JMP     UpdateTempMin       ; 当前温度<最低记录，更新最低温度
  1876                              
  1877                                  
  1878                              
  1879                              ;    RTS			
  1880                                  
  1881                              ;-------------------------------------------------------
  1882                              ; 更新湿度极值记录(BCD格式，无符号比较)
  1883                              ; 输入：R_DispHum - 当前湿度值(BCD格式)
  1884                              ;       R_HumMax, R_HumMin - 湿度最高/最低记录(BCD格式)
  1885                              ; 输出：更新R_HumMax, R_HumMin
  1886                              ; 说明：湿度没有正负号，因此直接按无符号大小更新最大/最小值即可。
  1887 0000F56E                     UpdateHumidityExtremes:
  1888                                  ; 比较当前湿度与最高湿度记录
  1889 0000F56E AD D2 01                LDA     R_DispHum
  1890 0000F571 CD D3 01                CMP     R_HumMax
  1891 0000F574 90 0D                   BCC     CheckHumMin         ; 如果当前湿度<=最高记录，检查最低记录
  1892                                  
  1893                                  ; 当前湿度>最高记录，更新最高湿度
  1894 0000F576 AD D2 01                LDA     R_DispHum
  1895 0000F579 8D D3 01                STA     R_HumMax
  1896 0000F57C AD C1 01                LDA		R_SpecFlag
  1897 0000F57F 8D C5 01            	STA		R_HumMax_Sign    
  1898 0000F582 60                  	RTS
  1899 0000F583                     CheckHumMin:
  1900                                  ; 比较当前湿度与最低湿度记录
  1901 0000F583 AD D2 01                LDA     R_DispHum
  1902 0000F586 CD D4 01                CMP     R_HumMin
  1903 0000F589 B0 0C                   BCS     ExitHumUpdate       ; 如果当前湿度>=最低记录，直接退出
  1904                                  
  1905                                  ; 当前湿度<最低记录，更新最低湿度
  1906 0000F58B AD D2 01                LDA     R_DispHum
  1907 0000F58E 8D D4 01                STA     R_HumMin
  1908 0000F591 AD C1 01                LDA		R_SpecFlag
  1909 0000F594 8D C4 01                STA		R_HumMin_Sign
  1910 0000F597                     ExitHumUpdate:
  1911 0000F597 60                      RTS    
  1912                              ;============================================================
  1913                              ; 温湿趋势判断 —— 窗口规格说明：
  1914                              ;   首次采样：当前值同时作为窗口 max/min，计数清零。
  1915                              ;   后续采样：当前值先尝试刷新窗口 max/min，再累计一次计数。
  1916                              ;   温度：当窗口 max-min > 1.0℃ 时，若本次刷新的是 max 则显示 Up，刷新的是 min 则显示 Down。
  1917                              ;   湿度：当窗口 max-min > 5%RH 时，若本次刷新的是 max 则显示 Up，刷新的是 min 则显示 Down。
  1918                              ;   方向触发后：该项目的窗口 max/min 重置为当前值，计数清零。
  1919                              ;   若 60 次采样内窗口跨度始终未触发阈值，则 EqCnt 饱和到 60，显示平缓。
  1920                              ;============================================================
  1921                              ; 函数: F_UpdateTrendState
  1922                              ; 作用: 趋势窗口算法入口，分别更新温度和湿度趋势状态。
  1923                              ; 输入: 当前温湿度原始值，以及窗口内保存的 max/min/counter。
  1924                              ; 输出: R_TrendFlags 的 Up/Down/Refresh 位，以及 R_TrendTempEqCnt/R_TrendHumEqCnt。
  1925                              ; 说明: 这里只保留 Init 位，方向位和刷新位只在本次采样真正触发图标变化时重新置位。
  1926 0000F598                     F_UpdateTrendState:
  1927 0000F598 AD B8 01                LDA     R_TrendFlags
  1928 0000F59B 29 01                   AND     #D_TrendInit
  1929 0000F59D F0 09                   BEQ     F_TrendSeedCurrent
  1930 0000F59F 8D B8 01                STA     R_TrendFlags
  1931 0000F5A2 20 E8 F5                JSR     F_UpdateTempTrendState
  1932 0000F5A5 4C 29 F7                JMP     F_UpdateHumTrendState
  1933                              
  1934                              ;-------------------------------------------------------
  1935                              ; 函数: F_TrendSeedCurrent
  1936                              ; 作用: 首次进入趋势逻辑时，用当前值建立温湿度窗口，并主动把趋势图标刷成平缓。
  1937                              ; 输出: Temp/Hum 窗口 max/min 均被初始化为当前值，EqCnt 置为 60，刷新位被置位。
  1938 0000F5A8                     F_TrendSeedCurrent:
  1939 0000F5A8 A9 01                   LDA     #D_TrendInit
  1940 0000F5AA 8D B8 01                STA     R_TrendFlags
  1941 0000F5AD 20 C1 F5                JSR     F_TrendResetTempWindowCurrent
  1942 0000F5B0 20 D9 F5                JSR     F_TrendResetHumWindowCurrent
  1943 0000F5B3 A9 3C                   LDA     #C_TrendEq60Min
  1944 0000F5B5 8D BF 01                STA     R_TrendTempEqCnt
  1945 0000F5B8 8D C0 01                STA     R_TrendHumEqCnt
  1946 0000F5BB A9 61                   LDA     #(D_TrendInit+D_TempTrendRefresh+D_HumTrendRefresh)
  1947 0000F5BD 8D B8 01                STA     R_TrendFlags
  1948 0000F5C0 60                      RTS
  1949                              
  1950                              ;-------------------------------------------------------
  1951                              ; 函数: F_TrendResetTempWindowCurrent
  1952                              ; 作用: 温度窗口重置为“当前值即 max/min”，并清零温度计数。
  1953 0000F5C1                     F_TrendResetTempWindowCurrent:
  1954 0000F5C1 AD 86 01                LDA     R_TempCH
  1955 0000F5C4 8D B9 01                STA     R_TrendTempMaxH
  1956 0000F5C7 8D BB 01                STA     R_TrendTempMinH
  1957 0000F5CA AD 87 01                LDA     R_TempCL
  1958 0000F5CD 8D BA 01                STA     R_TrendTempMaxL
  1959 0000F5D0 8D BC 01                STA     R_TrendTempMinL
  1960 0000F5D3 A9 00                   LDA     #00H
  1961 0000F5D5 8D BF 01                STA     R_TrendTempEqCnt
  1962 0000F5D8 60                      RTS
  1963                              
  1964                              ;-------------------------------------------------------
  1965                              ; 函数: F_TrendResetHumWindowCurrent
  1966                              ; 作用: 湿度窗口重置为“当前值即 max/min”，并清零湿度计数。
  1967 0000F5D9                     F_TrendResetHumWindowCurrent:
  1968 0000F5D9 AD 88 01                LDA     R_HUM
  1969 0000F5DC 8D BD 01                STA     R_TrendHumMax
  1970 0000F5DF 8D BE 01                STA     R_TrendHumMin
  1971 0000F5E2 A9 00                   LDA     #00H
  1972 0000F5E4 8D C0 01                STA     R_TrendHumEqCnt
  1973 0000F5E7 60                      RTS
  1974                              
  1975                              ;-------------------------------------------------------
  1976                              ; 函数: F_UpdateTempTrendState
  1977                              ; 作用: 按温度窗口 max/min 的扩张方向判定 Up/Down；若未触发则累计温度计数。
  1978                              ; 说明: 当前样本只有在刷新了窗口 max 或 min 时，才有可能触发方向变化。
  1979 0000F5E8                     F_UpdateTempTrendState:
  1980 0000F5E8 20 44 F6                JSR     F_TrendTempCurrentGtMax
  1981 0000F5EB 90 1C                   BCC     TrendTemp_CheckMin
  1982 0000F5ED AD 86 01                LDA     R_TempCH
  1983 0000F5F0 8D B9 01                STA     R_TrendTempMaxH
  1984 0000F5F3 AD 87 01                LDA     R_TempCL
  1985 0000F5F6 8D BA 01                STA     R_TrendTempMaxL
  1986 0000F5F9 20 CC F6                JSR     F_TrendTempSpanReached
  1987 0000F5FC 90 2C                   BCC     TrendTemp_StepCount
  1988 0000F5FE AD B8 01                LDA     R_TrendFlags
  1989 0000F601 09 22                   ORA     #(D_TempTrendUp+D_TempTrendRefresh)
  1990 0000F603 8D B8 01                STA     R_TrendFlags
  1991 0000F606 4C C1 F5                JMP     F_TrendResetTempWindowCurrent
  1992                              
  1993 0000F609                     TrendTemp_CheckMin:
  1994 0000F609 20 88 F6                JSR     F_TrendTempCurrentLtMin
  1995 0000F60C 90 1C                   BCC     TrendTemp_StepCount
  1996 0000F60E AD 86 01                LDA     R_TempCH
  1997 0000F611 8D BB 01                STA     R_TrendTempMinH
  1998 0000F614 AD 87 01                LDA     R_TempCL
  1999 0000F617 8D BC 01                STA     R_TrendTempMinL
  2000 0000F61A 20 CC F6                JSR     F_TrendTempSpanReached
  2001 0000F61D 90 0B                   BCC     TrendTemp_StepCount
  2002 0000F61F AD B8 01                LDA     R_TrendFlags
  2003 0000F622 09 24                   ORA     #(D_TempTrendDown+D_TempTrendRefresh)
  2004 0000F624 8D B8 01                STA     R_TrendFlags
  2005 0000F627 4C C1 F5                JMP     F_TrendResetTempWindowCurrent
  2006                              
  2007 0000F62A                     TrendTemp_StepCount:
  2008 0000F62A AD BF 01                LDA     R_TrendTempEqCnt
  2009 0000F62D C9 3C                   CMP     #C_TrendEq60Min
  2010 0000F62F B0 12                   BCS     TrendTemp_Exit
  2011 0000F631 EE BF 01                INC     R_TrendTempEqCnt
  2012 0000F634 AD BF 01                LDA     R_TrendTempEqCnt
  2013 0000F637 C9 3C                   CMP     #C_TrendEq60Min
  2014 0000F639 D0 08                   BNE     TrendTemp_Exit
  2015 0000F63B AD B8 01                LDA     R_TrendFlags
  2016 0000F63E 09 20                   ORA     #D_TempTrendRefresh
  2017 0000F640 8D B8 01                STA     R_TrendFlags
  2018 0000F643                     TrendTemp_Exit:
  2019 0000F643 60                      RTS
  2020                              
  2021                              ;-------------------------------------------------------
  2022                              ; 函数: F_TrendTempCurrentGtMax
  2023                              ; 作用: 判断当前温度是否大于窗口内的温度最大值。
  2024                              ; 输出: C=1 表示当前值 > TempMax，C=0 表示否。
  2025 0000F644                     F_TrendTempCurrentGtMax:
  2026 0000F644 AD 86 01                LDA     R_TempCH
  2027 0000F647 29 80                   AND     #80H
  2028 0000F649 F0 1C                   BEQ     TrendTempGtMax_CurrentPos
  2029                              
  2030                                  ; 当前温度为负：只有最大值也为负时才需要比较，且绝对值越小温度越大。
  2031 0000F64B AD B9 01                LDA     R_TrendTempMaxH
  2032 0000F64E 29 80                   AND     #80H
  2033 0000F650 F0 34                   BEQ     TrendTempGtMax_False
  2034 0000F652 AD 86 01                LDA     R_TempCH
  2035 0000F655 CD B9 01                CMP     R_TrendTempMaxH
  2036 0000F658 90 2A                   BCC     TrendTempGtMax_True
  2037 0000F65A D0 2A                   BNE     TrendTempGtMax_False
  2038 0000F65C AD 87 01                LDA     R_TempCL
  2039 0000F65F CD BA 01                CMP     R_TrendTempMaxL
  2040 0000F662 90 20                   BCC     TrendTempGtMax_True
