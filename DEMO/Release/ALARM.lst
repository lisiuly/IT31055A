  2112                              ; 函数: F_TrendTempSpanReached
  2113                              ; 作用: 判断当前温度窗口的 max/min 跨度是否已经超过 1.0℃。
  2114                              ; 输出: C=1 表示跨度已触发趋势，C=0 表示仍在平缓窗口内。
  2115                              ; 说明: 正温、负温和跨零三种情况分别计算，避免简单二进制比较在负温下失真。
  2116 0000F6CC                     F_TrendTempSpanReached:
  2117 0000F6CC AD B9 01                LDA     R_TrendTempMaxH
  2118 0000F6CF 29 80                   AND     #80H
  2119 0000F6D1 F0 1A                   BEQ     TrendTempSpan_MaxPositive
  2120                              
  2121                                  ; 两端都为负时，跨度 = 低温绝对值 - 高温绝对值，按 16 位 0.1℃ 值比较。
  2122 0000F6D3 38                      SEC
  2123 0000F6D4 AD BC 01                LDA     R_TrendTempMinL
  2124 0000F6D7 ED BA 01                SBC     R_TrendTempMaxL
  2125 0000F6DA AA                      TAX
  2126 0000F6DB AD BB 01                LDA     R_TrendTempMinH
  2127 0000F6DE ED B9 01                SBC     R_TrendTempMaxH
  2128 0000F6E1 90 44                   BCC     TrendTempSpan_False
  2129 0000F6E3 D0 40                   BNE     TrendTempSpan_True
  2130 0000F6E5 8A                      TXA
  2131 0000F6E6 C9 0B                   CMP     #C_TrendTempSpanTrig
  2132 0000F6E8 90 3D                   BCC     TrendTempSpan_False
  2133 0000F6EA 4C 25 F7                JMP     TrendTempSpan_True
  2134                              
  2135 0000F6ED                     TrendTempSpan_MaxPositive:
  2136 0000F6ED AD BB 01                LDA     R_TrendTempMinH
  2137 0000F6F0 29 80                   AND     #80H
  2138 0000F6F2 D0 1A                   BNE     TrendTempSpan_CrossZero
  2139                              
  2140                                  ; 两端都为正时，跨度 = 高温 - 低温，按 16 位 0.1℃ 值比较。
  2141 0000F6F4 38                      SEC
  2142 0000F6F5 AD BA 01                LDA     R_TrendTempMaxL
  2143 0000F6F8 ED BC 01                SBC     R_TrendTempMinL
  2144 0000F6FB AA                      TAX
  2145 0000F6FC AD B9 01                LDA     R_TrendTempMaxH
  2146 0000F6FF ED BB 01                SBC     R_TrendTempMinH
  2147 0000F702 90 23                   BCC     TrendTempSpan_False
  2148 0000F704 D0 1F                   BNE     TrendTempSpan_True
  2149 0000F706 8A                      TXA
  2150 0000F707 C9 0B                   CMP     #C_TrendTempSpanTrig
  2151 0000F709 90 1C                   BCC     TrendTempSpan_False
  2152 0000F70B 4C 25 F7                JMP     TrendTempSpan_True
  2153                              
  2154 0000F70E                     TrendTempSpan_CrossZero:
  2155                                  ; 跨零时，跨度 = 正温绝对值 + 负温绝对值，按 16 位 0.1℃ 值比较。
  2156 0000F70E 18                      CLC
  2157 0000F70F AD BA 01                LDA     R_TrendTempMaxL
  2158 0000F712 6D BC 01                ADC     R_TrendTempMinL
  2159 0000F715 AA                      TAX
  2160 0000F716 AD BB 01                LDA     R_TrendTempMinH
  2161 0000F719 29 7F                   AND     #7FH
  2162 0000F71B 6D B9 01                ADC     R_TrendTempMaxH
  2163 0000F71E D0 05                   BNE     TrendTempSpan_True
  2164 0000F720 8A                      TXA
  2165 0000F721 C9 0B                   CMP     #C_TrendTempSpanTrig
  2166 0000F723 90 02                   BCC     TrendTempSpan_False
  2167                              
  2168 0000F725                     TrendTempSpan_True:
  2169 0000F725 38                      SEC
  2170 0000F726 60                      RTS
  2171                              
  2172 0000F727                     TrendTempSpan_False:
  2173 0000F727 18                      CLC
  2174 0000F728 60                      RTS
