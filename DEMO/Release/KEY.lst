   667                      <       ; Macro Name:	%FillLcdDpram
   668                      <       ; Description:	Fill LCD DPRAM $3E00 ~$3FFF
   669                      <       ;-----------------------------------------------------------------------------
   670                      <       %FillLcdDpram	.MACRO	mData
   671                      <       		
   672                      <       		%WatchDogClear
   673                      <       		LDX		#00H
   674                      <       		LDY		#00H
   675                      <       ?L_ClrDpramLoop:
   676                      <       		LDA     mData
   677                      <       		STA		$3E00,X
   678                      <       		INY
   679                      <       		CPY		#04H
   680                      <       		BNE		?L_ClrDpramLoopI
   681                      <       		LDY		#00H
   682                      <       		TXA
   683                      <       		CLC
   684                      <       		ADC		#0CH
   685                      <       		TAX
   686                      <       ?L_ClrDpramLoopI:		
   687                      <       		INX
   688                      <       		CPX		#80H
   689                      <       		BNE		?L_ClrDpramLoop
   690                      <       	.ENDM
