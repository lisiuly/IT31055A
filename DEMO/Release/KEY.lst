   501                      <       ;;==========================================================================
   502                      <       ;;Macro Name: %M_SetPC7_Output             Attrib     Dir    Data
   503                      <       ;;Purpose: Set PortC7 driving  high          0         1      1
   504                      <       ;;Destroy: A
   505                      <       ;;==========================================================================
   506                      <       ;%M_SetPC7_OutputH:	.MACRO
   507                      <       ;        LDA		P_IO_PortC_Attrib
   508                      <       ;		AND     #7FH
   509                      <       ;		STA		P_IO_PortC_Attrib
   510                      <       ;		
   511                      <       ;		LDA		P_IO_PortC_Dir
   512                      <       ;		ORA     #80H
   513                      <       ;		STA		P_IO_PortC_Dir
   514                      <       ;		
   515                      <       ;		LDA		P_IO_PortC_Buffer
   516                      <       ;		ORA		#10000000B
   517                      <       ;		STA		P_IO_PortC_Data
   518                      <       ;		
   519                      <       ;			.ENDM
   520                      <       ;----------------------------------------------------------
   521                      <       ;/***********************************************/
   522                      <       ;         i.L=1 
   523                      <       %bits:   .MACRO   i,L             ;BYTE i;  
   524                      <                 lda     i               ;ex.  
   525                      <                 ora     #L              ;  %bits 10H,_BIT0
   526                      <       		                   ;  10H.0=1
   527                      <                 sta     i               ;
   528                      <                .ENDM    
   529                      <       
   530                      <       ;/***********************************************/
   531                      <       ;         i.L=0
   532                      <       %bitr:   .MACRO   i,L             ;BYTE i;  
   533                      <                 lda     i               ;ex.  
   534                      <                 and     #.NOT.L         ;  %bitr 10H,_BIT0;  10H.0=0
   535                      <                 sta     i
   536                      <                .ENDM    
   537                      <       
   538                      <       ;/***********************************************/
   539                      <       ;         if(i.L==1) goto N
   540                      <       %btst:   .MACRO   i,L,N           ;BYTE i;  
   541                      <                 lda     i               ;ex.   
   542                      <                 and     #L              ;  %btst 10H,_BIT0,N
   543                      <                 bne     N               ;  if(10H.0=1) goto N 
   544                      <                .ENDM    
   545                      <                                         
   546                      <       ;/***********************************************/
   547                      <       ;         if(i.L==0) goto N
   548                      <       %btsf:   .MACRO   i,L,N           ;BYTE i;    
   549                      <                 lda     i               ;ex.   
   550                      <                 and     #L              ;  %btsf 10H,_BIT0,N
   551                      <                 beq     N               ;  if(10H.0=0) goto N 
   552                      <                .ENDM    
   553                      <       ;/***********************************************/
   554                      <       ;         if(i==#0) goto N
   555                      <       %jz:     .MACRO   i,N             ;BYTE i;
   556                      <                 lda     i               ;ex.
   557                      <                 beq     N               ;  %jz 10H,N
   558                      <                .ENDM                    ;  if(10H==#0) goto N
   559                      <       
   560                      <       ;/***********************************************/
   561                      <       ;         if(i!=#0) goto N
   562                      <       %jnz:    .MACRO   i,N             ;BYTE i;
   563                      <                 lda     i               ;ex.
   564                      <                 bne     N               ;  %jnz 10H,N
   565                      <                .ENDM                    ;  if($10!=#0) goto N
