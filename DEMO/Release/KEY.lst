   406                      <       ;Macro Name: %DisableLCD
   407                      <       ;Purpose: Disable LCD
   408                      <       ;Destroy: A
   409                      <       ;;============================================================================
   410                      <       %DisableLCD:		.MACRO
   411                      <       	
   412                      <       		LDA		#(D_Duty_1_5+D_Bias_1_4)	;+D_ScanEnable)
   413                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
   414                      <       		
   415                      <       		LDA     #D_VLCD_33         ;VLCD = 4.5V (max value)
   416                      <       		STA     P_LCD_VLCD_Ctrl
   417                      <       	.ENDM
