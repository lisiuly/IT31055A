  1216 0000E46A                     F_KeyScan:	
  1217 0000E46A A5 03               		LDA		P_IO_PortE_Data
  1218 0000E46C 29 07               		AND		#(D_Bit2+D_Bit1+D_Bit0)
  1219 0000E46E F0 38               		BEQ		?ReleaseAllKey
  1220                              
  1221 0000E470 A9 00               		LDA		#00H
  1222 0000E472 85 97               		STA		R_KeyTemp
  1223                              
  1224 0000E474 A5 03               		LDA		P_IO_PortE_Data
  1225 0000E476 29 01               		AND		#D_Bit0
  1226 0000E478 F0 06               		BEQ		?L_CheckAllTimeKey
  1227 0000E47A A5 97               		LDA		R_KeyTemp
  1228 0000E47C 09 01               		ORA		#D_KeyFcClear
  1229 0000E47E 85 97               		STA		R_KeyTemp
  1230                              
  1231 0000E480                     	?L_CheckAllTimeKey:
  1232 0000E480 A5 03               		LDA		P_IO_PortE_Data
  1233 0000E482 29 02               		AND		#D_Bit1
  1234 0000E484 F0 06               		BEQ		?L_CheckLightKey
  1235 0000E486 A5 97               		LDA		R_KeyTemp
  1236 0000E488 09 02               		ORA		#D_KeyAllTime
  1237 0000E48A 85 97               		STA		R_KeyTemp
  1238                              
  1239 0000E48C                     	?L_CheckLightKey:
  1240 0000E48C A5 03               		LDA		P_IO_PortE_Data
  1241 0000E48E 29 04               		AND		#D_Bit2
  1242 0000E490 F0 06               		BEQ		?L_HaveKey
  1243 0000E492 A5 97               		LDA		R_KeyTemp
  1244 0000E494 09 04               		ORA		#D_KeyLight
  1245 0000E496 85 97               		STA		R_KeyTemp
  1246                              
  1247 0000E498                     	?L_HaveKey:
  1248 0000E498 A5 97               		LDA		R_KeyTemp
  1249 0000E49A C5 98               		CMP		R_KeyValue
  1250 0000E49C F0 42               		BEQ		?CheckKeyDebounce
  1251 0000E49E A5 97               		LDA		R_KeyTemp
  1252 0000E4A0 85 98               		STA		R_KeyValue
  1253 0000E4A2 A9 02               		LDA		#C_KeyDebounce
  1254 0000E4A4 85 9A               		STA		R_DebounceCnt
  1255 0000E4A6 58                  		CLI
  1256 0000E4A7 60                  		RTS
  1257                              				
  1258 0000E4A8                     ?ReleaseAllKey:					;°´¼üÊÍ·Å
  1259                              		%btst	R_KeyFlag,D_KeyRelDis,?L_Exit	
  1260 0000E4A8 A5 8F             1           lda     R_KeyFlag               ;ex.   
  1261 0000E4AA 29 10             1           and     #D_KeyRelDis              ;  %btst 10H,_BIT0,N
  1262 0000E4AC D0 1B             1           bne     ?L_Exit               ;  if(10H.0=1) goto N 
  1263 0000E4AE A5 99               		LDA	R_OldKeyValue
  1264 0000E4B0 F0 17               		BEQ	?L_Exit
  1265                              		
  1266 0000E4B2                     	?L_Dis_KeyTone:		
  1267 0000E4B2 A5 99               		LDA		R_OldKeyValue
  1268 0000E4B4 C9 04               		CMP		#D_KeyLight
  1269 0000E4B6 D0 03               		BNE		$+5		
  1270 0000E4B8 4C 7D E5            		JMP		Enable_LightKey			
  1271                              
  1272 0000E4BB C9 02               		CMP		#D_KeyAllTime
  1273 0000E4BD D0 03               		BNE		$+5		
  1274 0000E4BF 4C 12 E5            		JMP		Enable_AllTimeKey
  1275                              
  1276 0000E4C2 C9 01               		CMP		#D_KeyFcClear
  1277 0000E4C4 D0 03               		BNE		$+5		
  1278 0000E4C6 4C 44 E5            		JMP		Enable_FcClearKey
  1279                              		
  1280 0000E4C9                     	?L_Exit:		        ; ½«°´¼üÖµ±äÁ¿ÇåÁã£¬ÍË³ö
  1281 0000E4C9 A9 00               		LDA		#00
  1282 0000E4CB 85 99               		STA		R_OldKeyValue
  1283 0000E4CD 85 98               		STA		R_KeyValue
  1284 0000E4CF 85 97               		STA		R_KeyTemp
  1285 0000E4D1 A9 02               		LDA	#C_KeyDebounce
  1286 0000E4D3 85 9A               		STA	R_DebounceCnt
  1287 0000E4D5 A9 06               		LDA	#C_LongKey3Sec
  1288 0000E4D7 85 94               		STA	R_LongKeyTime
  1289                              		%bitr	R_KeyFlag,(D_EnableFastAdd+D_KeyRelDis)
  1290 0000E4D9 A5 8F             1           lda     R_KeyFlag               ;ex.  
  1291 0000E4DB 29 ED             1           and     #.NOT.(D_EnableFastAdd+D_KeyRelDis)         ;  %bitr 10H,_BIT0;  10H.0=0
  1292 0000E4DD 85 8F             1           sta     R_KeyFlag
  1293 0000E4DF 60                  		RTS
  1294                              		
  1295 0000E4E0                     ?CheckKeyDebounce:
  1296 0000E4E0 A5 9A               		LDA	R_DebounceCnt
  1297 0000E4E2 F0 01               		BEQ	?Key_Process		
  1298 0000E4E4 60                  		RTS	
  1299                              
  1300 0000E4E5                     	?Key_Process:
  1301 0000E4E5 A5 98               		LDA	R_KeyValue
  1302 0000E4E7 C5 99               		CMP	R_OldKeyValue
  1303 0000E4E9 F0 03               		BEQ	$+5
  1304 0000E4EB 4C 09 E5            		JMP	Enable_NewKey	
  1305                              		
  1306                              
  1307 0000E4EE                     Hold_Key:							;³¤°´°´¼ü¹¦ÄÜ
  1308 0000E4EE A5 94               		LDA		R_LongKeyTime
  1309 0000E4F0 D0 16               		BNE		?L_LongExit
  1310 0000E4F2 A9 06               		LDA		#C_LongKey3Sec
  1311 0000E4F4 85 94               		STA		R_LongKeyTime
  1312 0000E4F6 A5 99               		LDA		R_OldKeyValue
  1313 0000E4F8 29 02               		AND		#D_KeyAllTime
  1314 0000E4FA D0 09               		BNE		?L_LongAllTimeKey
  1315 0000E4FC A5 99               		LDA		R_OldKeyValue
  1316 0000E4FE 29 01               		AND		#D_KeyFcClear
  1317 0000E500 F0 06               		BEQ		?L_LongExit
  1318 0000E502 4C 5A E5            		JMP		Enable_longFcClearKey
  1319 0000E505                     	?L_LongAllTimeKey:
  1320 0000E505 4C 68 E5            		JMP		Enable_longAllTimeKey
  1321 0000E508                     	?L_LongExit:
  1322 0000E508 60                  		RTS
