   600                      <       %InitLCD:		.MACRO
   601                      <       
   602                      <       		LDA		#(D_Duty_1_5+D_Bias_1_3+D_ScanEnable)
   603                      <       		STA		P_LCD_Ctrl		;1/11duty,1/4bias,normal scan
