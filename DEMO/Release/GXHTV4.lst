   286                              ;;*****************
   287                              ;;crc校验，最高位是1就^0x31
   288                              ;高位数据放 R_temp1 低位数据放 R_temp0 crc数据放 R_temp2 进
   289                              ;相等返回 c=1 
   290 0000EEBA                     F_crc_check_handle:;
   291 0000EEBA A5 B1               	LDA		CNT4
   292 0000EEBC 85 AE               	STA		CNT1
   293 0000EEBE A5 B2               	LDA		CNT5
   294 0000EEC0 85 AF               	STA		CNT2
   295                              
   296 0000EEC2 A9 08               	LDA		#0x08
   297 0000EEC4 85 B0               	STA 	CNT3
   298 0000EEC6 A5 AE               	LDA 	CNT1
   299 0000EEC8 49 FF               	EOR  	#0xff
   300 0000EECA 85 AE               	STA 	CNT1
   301 0000EECC                     F_crc_check_h_loop:
   302 0000EECC A5 AE               	LDA		CNT1
   303 0000EECE 29 80               	AND		#0x80
   304                              ;	BIT		#BIT7
   305 0000EED0 F0 0C               	BEQ 	F_crc_check_h_loop_clr
   306 0000EED2                     F_crc_check_h_loop_set:
   307 0000EED2 18                  	CLC
   308 0000EED3 26 AE               	ROL 	CNT1 
   309 0000EED5 A5 AE               	LDA 	CNT1
   310 0000EED7 49 31               	EOR  	#0x31
   311 0000EED9 85 AE               	STA 	CNT1
   312 0000EEDB 4C E1 EE            	JMP 	F_crc_check_h_loop_0
   313 0000EEDE                     F_crc_check_h_loop_clr:
   314 0000EEDE 18                  	CLC 	
   315 0000EEDF 26 AE               	ROL 	CNT1
   316 0000EEE1                     F_crc_check_h_loop_0:
   317 0000EEE1 C6 B0               	DEC 	CNT3 
   318 0000EEE3 D0 E7               	BNE 	F_crc_check_h_loop
   319                              ;======================
   320 0000EEE5 A9 08               	LDA		#0x08
   321 0000EEE7 85 B0               	STA 	CNT3
   322 0000EEE9 A5 AE               	LDA 	CNT1			;前一位CRC结果
   323 0000EEEB 45 AF               	EOR 	CNT2
   324 0000EEED 85 AE               	STA 	CNT1
   325 0000EEEF                     F_crc_check_l_loop:
   326 0000EEEF A5 AE               	LDA		CNT1
   327 0000EEF1 29 80               	AND		#0x80
   328                              ;	BIT		#BIT7
   329 0000EEF3 F0 0C               	BEQ 	F_crc_check_l_loop_clr
   330 0000EEF5                     F_crc_check_l_loop_set:
   331 0000EEF5 18                  	clc	
   332 0000EEF6 26 AE               	ROL 	CNT1
   333 0000EEF8 A5 AE               	LDA 	CNT1
   334 0000EEFA 49 31               	EOR  	#0x31
   335 0000EEFC 85 AE               	STA 	CNT1
   336 0000EEFE 4C 04 EF            	JMP 	F_crc_check_l_loop_0
   337 0000EF01                     F_crc_check_l_loop_clr:
   338 0000EF01 18                  	CLC 	
   339 0000EF02 26 AE               	ROL 	CNT1
   340 0000EF04                     F_crc_check_l_loop_0:
   341 0000EF04 C6 B0               	DEC		CNT3
   342 0000EF06 D0 E7               	BNE 	F_crc_check_l_loop
   343                              ;================
   344 0000EF08 A5 AE               	LDA 	CNT1
   345 0000EF0A C5 B3               	CMP		CNT6
   346 0000EF0C D0 02               	BNE		F_crc_check_err
   347 0000EF0E 38                  	SEC 
   348 0000EF0F 60                  	RTS
   349 0000EF10                     F_crc_check_err:
   350 0000EF10 18                  	CLC
   351 0000EF11 60                  	RTS		
