    93                              
    94                              ; F_IIC_Set8bit 发送的是完整 8bit 地址字节，不是 7bit 地址。
    95                              ; 这里必须使用 0x44 左移一位后的写地址 0x88，
    96                              ; 否则起始写命令阶段就会发错地址，设备不会 ACK。
    97                              I2C_ID_GXHTV4		.equ				%10001000	; 8bit write address for 7bit slave 0x44
    98                              I2C_WRITE_BIT		.equ				%00000000 
    99                              I2C_READ_BIT		.equ				%00000001 
   100                              
   101                              ; GXHTV4 的测量命令是 1 byte，不是旧 SHT3x 风格的 16bit 0x2400。
   102                              CMD_MEASURE_TH		.EQU				0x24
   103                              
