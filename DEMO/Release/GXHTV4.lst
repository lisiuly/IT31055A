   183                              ;.COMMENT	@
   184                              ;  Input CNT4,CNT5
   185                              ;======================================================================
   186 0000EE24                     CAL_IC_TEMP:   ;IN:CNT4,CNT5
   187                                  ;T=(-450 + ST * 1750/65535)/10
   188 0000EE24 A5 B1                   	LDA            	CNT4
   189 0000EE26 85 B4                   	STA          	X_H
   190 0000EE28 A5 B2                   	LDA            	CNT5
   191 0000EE2A 85 B7                   	STA           	X_L
   192                                  	
   193 0000EE2C A9 D6                   	LDA          	#0D6H        ;1750 =6D6
   194 0000EE2E 85 B9                   	STA           	Y_L
   195 0000EE30 A9 06                   	LDA           	#06H
   196 0000EE32 85 B8                   	STA           	Y_H
   197 0000EE34 20 74 EF                	JSR            	MUL_HEX     ;/65536=10000H
   198 0000EE37 A9 FF                   	LDA	    		#0FFH
   199 0000EE39 85 B8                   	STA	   			Y_H
   200 0000EE3B A9 FF                   	LDA	    		#0FFH
   201 0000EE3D 85 B9                   	STA    			Y_L
   202 0000EE3F 20 12 EF            		JSR				DIV_HEX		;OUT:X
   203                              	
   204 0000EE42 38                  		SEC
   205 0000EE43 A5 B7               		LDA				X_L
   206 0000EE45 E9 C2               		SBC				#0xC2
   207 0000EE47 A5 B6               		LDA				X_M 
   208 0000EE49 E9 01               		SBC				#0x01
   209                               
   210 0000EE4B 90 23               		BCC            CAL_TEMP_PLUS
   211                              ;=======  + =======================
   212 0000EE4D 38                  		SEC
   213 0000EE4E A5 B7               		LDA				X_L
   214 0000EE50 E9 C2               		SBC				#0xC2
   215 0000EE52 85 AC               		STA				TEMP_INTEGAL
   216 0000EE54 A5 B6               		lda				X_M
   217 0000EE56 E9 01               		SBC				#0x01
   218 0000EE58 85 AB                    	STA				TEMP_INTEGAH
   219                              
   220 0000EE5A 38                  		SEC
   221 0000EE5B A5 AC               		LDA			TEMP_INTEGAL
   222 0000EE5D E9 BC               		SBC			#0xBC
   223 0000EE5F A5 AB               		LDA			TEMP_INTEGAH
   224 0000EE61 E9 02               		SBC			#0x02
   225                              
   226 0000EE63 90 31                   	BCC			CAL_TEMP_OUT
   227 0000EE65 A9 02                   	LDA			#02H
   228 0000EE67 85 AB                   	STA			TEMP_INTEGAH
   229 0000EE69 A9 BC                   	LDA			#0BCH
   230 0000EE6B 85 AC                   	STA			TEMP_INTEGAL
   231 0000EE6D 4C 96 EE                	JMP			CAL_TEMP_OUT
   232 0000EE70                     CAL_TEMP_PLUS: ; -
   233 0000EE70 38                  		SEC
   234 0000EE71 A9 C2               		LDA			#0C2H
   235 0000EE73 E5 B7               		SBC			X_L 
   236 0000EE75 85 AC               		STA			TEMP_INTEGAL
   237 0000EE77 A9 01               		LDA			#0X01
   238 0000EE79 E5 B6               		SBC			X_M 
   239 0000EE7B 85 AB               		STA			TEMP_INTEGAH
   240                              ;		BSF			TEMP_INTEGAH,BIT7		;-
   241 0000EE7D A5 AB               		LDA			TEMP_INTEGAH
   242 0000EE7F 09 80               		ORA			#0x80
   243 0000EE81 85 AB               		STA			TEMP_INTEGAH
   244                              
   245 0000EE83 38                  		SEC
   246 0000EE84 A5 AC               		LDA			TEMP_INTEGAL
   247 0000EE86 E9 C8               		SBC			#0xC8
   248 0000EE88 A5 AB               		LDA			TEMP_INTEGAH
   249 0000EE8A E9 80               		SBC			#0x080
   250 0000EE8C 90 08               		BCC			CAL_TEMP_OUT
   251 0000EE8E A9 80                   	LDA			#080H
   252 0000EE90 85 AB                   	STA			TEMP_INTEGAH
   253 0000EE92 A9 C8                   	LDA			#0C8H
   254 0000EE94 85 AC                   	STA			TEMP_INTEGAL
   255 0000EE96                     CAL_TEMP_OUT:
   256 0000EE96 60                  		RTS
   257                              ;======================================================================
   258                              ;======================================================================
   259 0000EE97                     CAL_IC_HUM:   ;IN:CNT4,CNT5
   260                                  ;T=100* S / 65533
   261 0000EE97 A5 B1                   	LDA      	CNT4
   262 0000EE99 85 B4               		STA        	X_H
   263 0000EE9B A5 B2                   	LDA       	CNT5
   264 0000EE9D 85 B7                   	STA        	X_L
   265 0000EE9F A9 64                   	LDA      	#064H        ;125 = 7D
   266 0000EEA1 85 B9                   	STA     	Y_L
   267 0000EEA3 A9 00                   	LDA			#00
   268 0000EEA5 85 B8                   	STA        	Y_H
   269 0000EEA7 20 74 EF                	JSR         MUL_HEX     ;/65536=10000H
   270 0000EEAA A9 FF                   	LDA	    	#0FFH
   271 0000EEAC 85 B8                   	STA	   		Y_H
   272 0000EEAE A9 FD                   	LDA	    	#0FDH
   273 0000EEB0 85 B9                   	STA    		Y_L
   274 0000EEB2 20 12 EF            		JSR			DIV_HEX		;OUT:X
   275 0000EEB5 A5 B7               		LDA			X_L
   276 0000EEB7 85 AD               		STA			HUM
   277                              ;======================
   278                              ;		BBR7		HUM,CAL_HUM_OUT
   279                              ;		LDA			#00H
   280                              ;   	STA             HUM
   281 0000EEB9                     CAL_HUM_OUT:
   282                              ;==========================================
   283                              ;==========================================
   284 0000EEB9 60                  		RTS
