   355 0000EF12                     DIV_HEX:;IN:OUT_H,OUT_1,OUT_M,OUT_L; Y_H,Y_L;OUT:X_H,X_1,X_M,X_L
   356                              	;余数:CNT5,CNT6: USE:X,Y
   357 0000EF12 A9 00               	lda		#00
   358 0000EF14 85 B4               	STA		X_H
   359 0000EF16 85 B5               	STA		X_1
   360 0000EF18 85 B6               	STA		X_M
   361 0000EF1A 85 B7               	STA		X_L
   362                              
   363 0000EF1C 85 AF               	STA		CNT2
   364 0000EF1E 85 B0               	STA		CNT3
   365 0000EF20 85 B1               	STA		CNT4
   366                              
   367 0000EF22 A5 B8               	LDA		Y_H;除数为零跳出
   368 0000EF24 D0 04               	BNE		NDIV1;Z=0
   369 0000EF26 A5 B9               	LDA		Y_L
   370 0000EF28 F0 49               	BEQ		NDIV_END;Z=1
   371 0000EF2A                     NDIV1:
   372 0000EF2A A2 20               	LDX		#32;16
   373 0000EF2C                     NDIV2:
   374 0000EF2C 18                  	CLC
   375 0000EF2D 26 BA               	ROL		OUT_L	;被除数
   376 0000EF2F 26 BB               	ROL		OUT_M
   377 0000EF31 26 BC               	ROL		OUT_1
   378 0000EF33 26 BD               	ROL		OUT_H
   379                              
   380 0000EF35 26 B1               	ROL		CNT4	;余数
   381 0000EF37 26 B0               	ROL		CNT3
   382 0000EF39 26 AF               	ROL		CNT2	;溢出位
   383                              
   384 0000EF3B 26 B7               	ROL		X_L		;OUT????????
   385 0000EF3D 26 B6               	ROL		X_M
   386 0000EF3F 26 B5               	ROL		X_1
   387 0000EF41 26 B4               	ROL		X_H
   388                              
   389 0000EF43 A5 AF               	LDA		CNT2
   390 0000EF45 D0 16               	BNE		NDIV_SUB	;Z=0
   391 0000EF47 38                  	SEC
   392 0000EF48 A5 B0               	LDA		CNT3
   393 0000EF4A E5 B8               	SBC		Y_H
   394 0000EF4C F0 05               	BEQ		NDIV_7	;Z=1
   395 0000EF4E B0 0D               	BCS		NDIV_SUB
   396 0000EF50 4C 70 EF            	JMP		NDIV4	;不够减????
   397 0000EF53                     NDIV_7:
   398 0000EF53 38                  	SEC
   399 0000EF54 A5 B1               	LDA		CNT4
   400 0000EF56 E5 B9               	SBC		Y_L
   401 0000EF58 B0 03               	BCS		NDIV_SUB;C=1
   402 0000EF5A 4C 70 EF            	JMP		NDIV4	;不够减
   403 0000EF5D                     NDIV_SUB:
   404 0000EF5D A9 00               	LDA		#00
   405 0000EF5F 85 AF               	STA		CNT2
   406 0000EF61 38                  	SEC
   407 0000EF62 A5 B1               	LDA		CNT4
   408 0000EF64 E5 B9               	SBC		Y_L
   409 0000EF66 85 B1               	STA		CNT4
   410 0000EF68 A5 B0               	LDA		CNT3
   411 0000EF6A E5 B8               	SBC		Y_H
   412 0000EF6C 85 B0               	STA		CNT3
   413                              
   414 0000EF6E E6 B7               	INC		X_L	;OUT LOW BIT
   415                              
   416 0000EF70                     NDIV4:
   417 0000EF70 CA                  	DEX
   418 0000EF71 D0 B9               	BNE		NDIV2	;Z=0
   419                              
   420 0000EF73                     NDIV_END:
   421 0000EF73 60                  	RTS
