   109 0000EDBA                     .CODE
   110                              ;==========================================
   111                              ; IRQ INTERRUPT SERVICE ROUTINE
   112                              ;==========================================
   113                              ;======================================================================
   114                              ; 通过 D_I2C 底层发送转换命令，再读取 6 字节原始数据。
   115                              ; 读取成功后更新 TEMP_INTEGAH/TEMP_INTEGAL/HUM。
   116                              ;======================================================================
   117 0000EDBA                     F_ReadGXHTV4Data:
   118 0000EDBA 20 2C F1            		JSR			F_IIC_start
   119 0000EDBD A0 88               		LDY			#I2C_ID_GXHTV4
   120 0000EDBF 20 52 F1            		JSR			F_IIC_Set8bit
   121 0000EDC2 20 BD F1            		JSR			F_RACK
   122 0000EDC5 90 42               		BCC			F_ReadGXHTV4StopExit
   123 0000EDC7 A0 24               		LDY			#CMD_MEASURE_TH
   124 0000EDC9 20 52 F1            		JSR			F_IIC_Set8bit
   125 0000EDCC 20 BD F1            		JSR			F_RACK
   126 0000EDCF 90 38               		BCC			F_ReadGXHTV4StopExit
   127 0000EDD1 20 3F F1            		JSR			F_IIC_stop
   128                              
   129 0000EDD4 20 0D EE            		JSR			F_GXHTV4WaitReady
   130 0000EDD7 20 3A F2            		JSR			F_I2C_ReadData
   131                              
   132 0000EDDA AD C6 00            		LDA			R_SaveData+0
   133 0000EDDD 85 B1               		STA			CNT4
   134 0000EDDF AD C7 00            		LDA			R_SaveData+1
   135 0000EDE2 85 B2               		STA			CNT5
   136 0000EDE4 AD C8 00            		LDA			R_SaveData+2
   137 0000EDE7 85 B3               		STA			CNT6
   138 0000EDE9 20 BA EE            		JSR			F_crc_check_handle
   139 0000EDEC 90 1E               		BCC			F_ReadGXHTV4Data_Exit
   140 0000EDEE 20 24 EE            		JSR			CAL_IC_TEMP
   141                              
   142 0000EDF1 AD C9 00            		LDA			R_SaveData+3
   143 0000EDF4 85 B1               		STA			CNT4
   144 0000EDF6 AD CA 00            		LDA			R_SaveData+4
   145 0000EDF9 85 B2               		STA			CNT5
   146 0000EDFB AD CB 00            		LDA			R_SaveData+5
   147 0000EDFE 85 B3               		STA			CNT6
   148 0000EE00 20 BA EE            		JSR			F_crc_check_handle
   149 0000EE03 90 07               		BCC			F_ReadGXHTV4Data_Exit
   150 0000EE05 20 97 EE            		JSR			CAL_IC_HUM
   151 0000EE08 60                  		RTS
   152                              
   153 0000EE09                     F_ReadGXHTV4StopExit:
   154 0000EE09 20 3F F1            		JSR			F_IIC_stop
   155                              
   156 0000EE0C                     F_ReadGXHTV4Data_Exit:
   157 0000EE0C 60                  		RTS
   158                              
   159 0000EE0D                     F_GXHTV4WaitReady:
   160                              		; 0x24 是 0.1s 加热测量命令，这里等待约 160ms，先把“时间不够”排除掉。
   161 0000EE0D A9 02               		LDA			#02H
   162 0000EE0F 48                  		PHA
   163 0000EE10                     F_GXHTV4WaitReady_A:
   164 0000EE10 A0 FF               		LDY			#0FFH
   165 0000EE12                     F_GXHTV4WaitReady_Y:
   166 0000EE12 A2 FF               		LDX			#0FFH
   167 0000EE14                     F_GXHTV4WaitReady_X:
   168 0000EE14 CA                  		DEX
   169 0000EE15 D0 FD               		BNE			F_GXHTV4WaitReady_X
   170 0000EE17 88                  		DEY
   171 0000EE18 D0 F8               		BNE			F_GXHTV4WaitReady_Y
   172 0000EE1A 68                  		PLA
   173 0000EE1B 38                  		SEC
   174 0000EE1C E9 01               		SBC			#01H
   175 0000EE1E F0 03               		BEQ			F_GXHTV4WaitReady_Done
   176 0000EE20 48                  		PHA
   177 0000EE21 D0 ED               		BNE			F_GXHTV4WaitReady_A
   178                              		
   179 0000EE23                     F_GXHTV4WaitReady_Done:
   180 0000EE23 60                  		RTS
   181                              
