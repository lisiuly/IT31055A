   423 0000EF74                     MUL_HEX:;双字节 * 双字节 -->4字节;IN:X_H,X_L ; Y_H,Y_L,
   424                              	;OUT:OUT_H,OUT_1,OUT_M,OUT_L;
   425 0000EF74 A9 00               	LDA		#00H
   426 0000EF76 85 BD               	STA		OUT_H;清零
   427 0000EF78 85 BC               	STA		OUT_1
   428 0000EF7A 85 BB               	STA		OUT_M
   429 0000EF7C 85 BA               	STA		OUT_L
   430 0000EF7E A2 10               	LDX		#$10	;16BIT
   431 0000EF80                     MUL_LOOP:
   432                              ;	CLC
   433 0000EF80 06 BA               	ASL		OUT_L
   434 0000EF82 26 BB               	ROL		OUT_M
   435 0000EF84 26 BC               	ROL		OUT_1
   436 0000EF86 26 BD               	ROL		OUT_H
   437                              
   438 0000EF88 26 B9               	ROL		Y_L
   439 0000EF8A 26 B8               	ROL		Y_H
   440 0000EF8C 90 19               	BCC		TO_LOOP0	;C=0 JMP
   441 0000EF8E 18                  	CLC		;CLEAR C
   442 0000EF8F A5 B7               	LDA		X_L
   443 0000EF91 65 BA               	ADC		OUT_L
   444 0000EF93 85 BA               	STA		OUT_L
   445 0000EF95 A5 B4               	LDA		X_H
   446 0000EF97 65 BB               	ADC		OUT_M
   447 0000EF99 85 BB               	STA		OUT_M
   448 0000EF9B A9 00               	LDA		#00
   449 0000EF9D 65 BC               	ADC		OUT_1
   450 0000EF9F 85 BC               	STA		OUT_1
   451 0000EFA1 A9 00               	LDA		#00
   452 0000EFA3 65 BD               	ADC		OUT_H
   453 0000EFA5 85 BD               	STA		OUT_H
   454 0000EFA7                     TO_LOOP0:
   455 0000EFA7 CA                  	DEX
   456 0000EFA8 D0 D6               	BNE		MUL_LOOP  	;Z=0	
   457 0000EFAA 60                  	RTS
